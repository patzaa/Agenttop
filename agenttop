def safe_addstr(stdscr, y, x, s, attr=0, w=None):
    """addnstr that never throws on edge writes."""
    if w is None:
        _, w = stdscr.getmaxyx()
    if y >= stdscr.getmaxyx()[0] or y < 0:
        return
    max_len = w - x - 1
    if max_len <= 0:
        return
    try:
        stdscr.addnstr(y, x, s, max_len, attr)
    except curses.error:
        pass


def _split_widths(w: int) -> tuple:
    """Returns (launchd_width, claude_width) or (full, 0) if too narrow."""
    if w < 130:
        return (w, 0)
    launchd_w = max(70, min(w * 55 // 100, 100))
    claude_w = w - launchd_w - 1  # 1 col separator
    return (launchd_w, claude_w)


