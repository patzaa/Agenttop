def draw_claude_pane(stdscr, x0, y0, w, h, index: ClaudeIndex,
                     limits: 'LimitsFetcher',
                     window_mode: str, sel_idx: int, focused: bool):
    """Renders the Claude usage pane. Returns (sel_idx, sessions_list)."""
    now = datetime.now().timestamp()
    since, until, label = window_bounds(window_mode, now)
    agg = index.aggregate(since=since, until=until)

    # B2: Fokus traegt das GEWICHT, nicht die Farbe — unfokussiert wird gedimmt.
    title_attr = curses.A_BOLD if focused else (curses.A_BOLD | curses.A_DIM)
    safe_addstr(stdscr, y0, x0, "CLAUDE", title_attr, x0 + w)
    safe_addstr(stdscr, y0, x0 + 6, f"  window: {label}  (v cycle)", 0, x0 + w)

    y = y0 + 2

    # ── Anthropic real limits (from /v1/messages response headers) ──
    safe_addstr(stdscr, y, x0,
                "Anthropic limits (live from API headers)",
                curses.A_UNDERLINE, x0 + w)
    y += 1
    ld = limits.data or {}
    bar_w = max(8, w - 30)
    if ld and "error" not in ld:
        for label_, util_key, reset_key, status_key in (
            ("5h", "5h_util", "5h_reset", "5h_status"),
            ("7d", "7d_util", "7d_reset", "7d_status"),
        ):
            util = ld.get(util_key)
            status = ld.get(status_key) or "?"
            reset = ld.get(reset_key)
            if util is None:
                safe_addstr(stdscr, y, x0,
                            f"  {label_}  (header missing)",
                            curses.A_DIM, x0 + w)
                y += 1
                continue
            bar = _bar(min(1.0, util), bar_w)
            if util >= 0.95:
                attr = curses.color_pair(2) | curses.A_BOLD
            elif util >= 0.8:
                attr = curses.color_pair(3) | curses.A_BOLD
            else:
                attr = 0
            if reset:
                secs = max(0, int(reset - now))
                if secs >= 60:
                    reset_str = _fmt_duration(secs / 60)
                else:
                    reset_str = f"{secs}s"
            else:
                reset_str = "?"
            line = (f"  {label_}  {int(util * 100):>3}% {bar} "
                    f"reset {reset_str:<7} {status}")
            safe_addstr(stdscr, y, x0, line, attr, x0 + w)
            y += 1
        # Footer: cache age + refresh hint
        age = int(limits.age_seconds())
        age_str = "fetching…" if limits.fetching else (
            f"{age}s ago" if age < 60 else
            f"{age // 60}m ago" if age < 3600 else
            f"{age // 3600}h ago"
        )
        safe_addstr(stdscr, y, x0,
                    f"  fetched {age_str}  (f to refresh)",
                    curses.A_DIM, x0 + w)
        y += 2
    elif ld and "error" in ld:
        safe_addstr(stdscr, y, x0, f"  error: {ld['error'][:60]}",
                    curses.color_pair(2), x0 + w)
        y += 1
        if limits.fetching:
            safe_addstr(stdscr, y, x0, "  retrying…", curses.A_DIM, x0 + w)
        else:
            safe_addstr(stdscr, y, x0, "  press 'f' to retry",
                        curses.A_DIM, x0 + w)
        y += 2
    else:
        msg = "  fetching…" if limits.fetching else "  press 'f' to fetch"
        safe_addstr(stdscr, y, x0, msg, curses.A_DIM, x0 + w)
        y += 2

    # ── Local activity (from your Claude Code logs) ──
    safe_addstr(stdscr, y, x0,
                f"Local activity (window: {label})",
                curses.A_UNDERLINE, x0 + w)
    y += 1
    totals = agg["totals"]
    since_str = datetime.fromtimestamp(since).strftime("%H:%M")
    until_str = datetime.fromtimestamp(until).strftime("%H:%M")
    line1 = f"  {since_str}–{until_str}  {len(agg['by_session'])} sess  {totals['msgs']} msgs"
    safe_addstr(stdscr, y, x0, line1, curses.A_DIM, x0 + w)
    y += 1
    line2 = (
        f"  in {_fmt_tokens(totals['in_'])}   "
        f"out {_fmt_tokens(totals['out'])}   "
        f"cache {_fmt_tokens(totals['cc'] + totals['cr'])}"
    )
    safe_addstr(stdscr, y, x0, line2, 0, x0 + w)
    y += 2

    # By model
    by_model = agg["by_model"]
    if by_model:
        safe_addstr(stdscr, y, x0, "By model", curses.A_UNDERLINE, x0 + w)
        y += 1
        ranked = sorted(by_model.items(), key=lambda kv: -total_tokens(kv[1]))
        biggest = max(total_tokens(b) for _, b in ranked) or 1
        bar_w = max(6, w - 32)
        for model, b in ranked[:4]:
            if y >= y0 + h - 2:
                break
            v = total_tokens(b)
            frac = v / biggest if biggest else 0
            name = _short_model(model)[:14]
            line = f"  {name:<14} {_bar(frac, bar_w)}  {_fmt_tokens(v):>6}"
            safe_addstr(stdscr, y, x0, line, 0, x0 + w)
            y += 1
        y += 1

    # By project
    by_proj = agg["by_project"]
    if by_proj and y < y0 + h - 6:
        safe_addstr(stdscr, y, x0, "By project", curses.A_UNDERLINE, x0 + w)
        y += 1
        ranked = sorted(by_proj.items(), key=lambda kv: -total_tokens(kv[1]))
        biggest = max(total_tokens(b) for _, b in ranked) or 1
        bar_w = max(6, w - 32)
        for proj, b in ranked[:4]:
            if y >= y0 + h - 2:
                break
            v = total_tokens(b)
            frac = v / biggest if biggest else 0
            name = (proj or "?")[:14]
            line = f"  {name:<14} {_bar(frac, bar_w)}  {_fmt_tokens(v):>6}"
            safe_addstr(stdscr, y, x0, line, 0, x0 + w)
            y += 1
        y += 1

    # Active sessions (selectable)
    sessions = sorted(
        agg["by_session"].items(),
        key=lambda kv: -kv[1]["last"],
    )
    # Always return the full session list so Enter can dispatch on sel_idx,
    # even if the visible window is smaller than the list.
    sessions_list = list(sessions)
    if sessions and y < y0 + h - 4:
        safe_addstr(stdscr, y, x0, "Sessions", curses.A_UNDERLINE, x0 + w)
        y += 1
        if sel_idx >= len(sessions):
            sel_idx = max(0, len(sessions) - 1)
        if sel_idx < 0:
            sel_idx = 0
        max_rows = max(1, y0 + h - y - 4)  # leave room for 7d trend
        sw_start = max(0, min(sel_idx - max_rows // 2,
                              max(0, len(sessions) - max_rows)))
        for i, (sid, b) in enumerate(sessions[sw_start:sw_start + max_rows]):
            actual_i = sw_start + i
            is_sel = focused and (actual_i == sel_idx)
            sel_attr = curses.A_REVERSE if is_sel else 0
            sm = index.session_meta.get(sid, {})
            branch = sm.get("branch") or ""
            cwd = sm.get("cwd") or ""
            # Prefer git branch; fall back to cwd basename; fall back to project.
            if branch:
                ident = _short_branch(branch, 22)
            elif cwd:
                ident = _short_branch(os.path.basename(cwd) or "?", 22)
            else:
                ident = (b["project"] or "?")[:22]
            model = _short_model(b["model"])[:11]
            rel = _fmt_relative(b["last"], now)
            tok = _fmt_tokens(total_tokens(b))
            line = f"  {ident:<22} {model:<11} {rel:<8} {tok:>6}  {sid[:6]}"
            safe_addstr(stdscr, y, x0, line.ljust(w), sel_attr, x0 + w)
            y += 1
        y += 1

    # 24h chart — peak tokens/min per hour, two sparklines stacked.
    # Same metric the Anthropic Console shows on the rate-limit graph,
    # computed from your local JSONL (which logs Anthropic's usage values verbatim).
    if y < y0 + h - 4:
        safe_addstr(stdscr, y, x0,
                    "Last 24h — peak tokens/min per hour",
                    curses.A_UNDERLINE, x0 + w)
        y += 1
        peaks = index.hourly_peaks(now, hours=24)
        in_vals = [p["max_in"] for p in peaks]
        out_vals = [p["max_out"] for p in peaks]
        in_max = max(in_vals) if in_vals else 0
        out_max = max(out_vals) if out_vals else 0
        spark_w = min(24, max(8, w - 26))
        # Trim to last `spark_w` hours so the chart fits the pane width
        in_view = in_vals[-spark_w:]
        out_view = out_vals[-spark_w:]
        peaks_view = peaks[-spark_w:]
        in_spark = _sparkline(in_view, in_max)
        out_spark = _sparkline(out_view, out_max)

        def peak_label(vals, m):
            if m <= 0:
                return ""
            i = vals.index(m)
            t = datetime.fromtimestamp(peaks_view[i]["hour_ts"]).strftime("%H:%M")
            return f"  peak {_fmt_tokens(m)} @{t}"

        safe_addstr(stdscr, y, x0,
                    f"  in   {in_spark}{peak_label(in_view, in_max)}",
                    curses.color_pair(1), x0 + w)
        y += 1
        safe_addstr(stdscr, y, x0,
                    f"  out  {out_spark}{peak_label(out_view, out_max)}",
                    curses.color_pair(5), x0 + w)
        y += 1
        if peaks_view:
            t0 = datetime.fromtimestamp(peaks_view[0]["hour_ts"]).strftime("%H:%M")
            tn = datetime.fromtimestamp(peaks_view[-1]["hour_ts"]).strftime("%H:%M")
            axis = f"       {t0}{' ' * max(1, spark_w - 10)}{tn}"
            safe_addstr(stdscr, y, x0, axis, curses.A_DIM, x0 + w)
            y += 1

    return sel_idx, sessions_list


