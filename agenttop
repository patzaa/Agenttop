def fetch_anthropic_limits() -> dict:
    """Fetch real anthropic-ratelimit-* headers by running a tiny `claude -p .` call.

    The headers come from Anthropic's API response, parsed verbatim — no math
    or estimation on this side. Each call costs one billable message, so callers
    must rate-limit (this is the raw fetch; caching is in LimitsFetcher).
    """
    env = {**os.environ, "ANTHROPIC_LOG": "debug"}
    try:
        r = subprocess.run(
            ["claude", "--no-session-persistence", "-p", "."],
            capture_output=True, text=True, timeout=60, env=env,
        )
    except (subprocess.TimeoutExpired, FileNotFoundError) as e:
        return {"error": f"claude call failed: {e}", "ts": time.time()}

    text = r.stdout + r.stderr
    pat = re.compile(r'"(anthropic-ratelimit-[a-z0-9-]+)":\s*"([^"]+)"')
    headers = {}
    for k, v in pat.findall(text):
        headers[k] = v

    if not headers:
        return {
            "error": "no anthropic-ratelimit-* headers in response",
            "ts": time.time(),
        }

    def gf(k):
        try: return float(headers[k])
        except (KeyError, ValueError): return None
    def gi(k):
        try: return int(headers[k])
        except (KeyError, ValueError): return None

    return {
        "ts": time.time(),
        "5h_util": gf("anthropic-ratelimit-unified-5h-utilization"),
        "5h_reset": gi("anthropic-ratelimit-unified-5h-reset"),
        "5h_status": headers.get("anthropic-ratelimit-unified-5h-status"),
        "7d_util": gf("anthropic-ratelimit-unified-7d-utilization"),
        "7d_reset": gi("anthropic-ratelimit-unified-7d-reset"),
        "7d_status": headers.get("anthropic-ratelimit-unified-7d-status"),
        "status": headers.get("anthropic-ratelimit-unified-status"),
        "representative": headers.get("anthropic-ratelimit-unified-representative-claim"),
    }


class LimitsFetcher:
    """Caches Anthropic rate-limit headers; refreshes async on demand.

    State lives in ~/.cache/launchd-top/anthropic-limits.json so cache survives
    restarts. Background thread fetches; main loop reads `data` cheaply.
    """

    def __init__(self):
        self.data: dict = {}
        self.fetching: bool = False
        self.lock = threading.Lock()
        self._load_cache()

    def _load_cache(self):
        for path in (LIMITS_CACHE, LEGACY_CACHE):
            try:
                self.data = json.loads(path.read_text())
                return
            except (OSError, json.JSONDecodeError):
                continue
        self.data = {}

    def age_seconds(self) -> float:
        ts = (self.data or {}).get("ts", 0)
        return max(0, time.time() - ts) if ts else float("inf")

    def is_stale(self, ttl: int = LIMITS_TTL_SECONDS) -> bool:
        if not self.data or "error" in self.data:
            return True
        return self.age_seconds() > ttl

    def fetch_async(self):
        with self.lock:
            if self.fetching:
                return
            self.fetching = True
        t = threading.Thread(target=self._fetch_blocking, daemon=True)
        t.start()

    def _fetch_blocking(self):
        try:
            result = fetch_anthropic_limits()
            with self.lock:
                self.data = result
            try:
                LIMITS_CACHE.parent.mkdir(parents=True, exist_ok=True)
                LIMITS_CACHE.write_text(json.dumps(result))
            except OSError:
                pass
        finally:
            with self.lock:
                self.fetching = False

# ── launchd data layer ──────────────────────────────────────────────


def parse_plist(path: Path):
    r = subprocess.run(
        ["plutil", "-convert", "json", "-o", "-", str(path)],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        return None
    try:
        return json.loads(r.stdout)
    except json.JSONDecodeError:
        return None


def schedule_str(plist: dict) -> str:
    if "StartCalendarInterval" in plist:
        sci = plist["StartCalendarInterval"]
        if isinstance(sci, dict):
            sci = [sci]
        parts = []
        for d in sci:
            day = WEEKDAYS[d["Weekday"] % 7] if "Weekday" in d else "*"
            hour = d.get("Hour")
            mn = d.get("Minute", 0)
            time = f"{hour:02d}:{mn:02d}" if hour is not None else "*"
            parts.append(f"{day} {time}")
        if len(parts) > 1:
            times = {p.split(" ", 1)[1] for p in parts}
            if len(times) == 1:
                days = ",".join(p.split(" ", 1)[0] for p in parts)
                return f"{days} {times.pop()}"
        return ", ".join(parts)
    if "StartInterval" in plist:
        s = plist["StartInterval"]
        for unit, n in (("d", 86400), ("h", 3600), ("m", 60)):
            if s >= n and s % n == 0:
                return f"every {s // n}{unit}"
        return f"every {s}s"
    if plist.get("KeepAlive"):
        return "keep-alive"
    if plist.get("RunAtLoad"):
        return "at load"
    if "WatchPaths" in plist:
        return "on path change"
    return "-"


def status_map() -> dict:
    r = subprocess.run(["launchctl", "list"], capture_output=True, text=True)
    s = {}
    for line in r.stdout.splitlines()[1:]:
        parts = line.split(None, 2)
        if len(parts) == 3:
            pid, code, label = parts
            s[label] = (pid, code)
    return s


def human_size(n):
    if n is None:
        return "-"
    if n < 1024:
        return f"{n}B"
    if n < 1024 * 1024:
        return f"{n // 1024}K"
    if n < 1024 ** 3:
        return f"{n / (1024 ** 2):.1f}M"
    return f"{n / (1024 ** 3):.1f}G"


def log_size(plist: dict):
    path = plist.get("StandardOutPath") or plist.get("StandardErrorPath")
    if not path:
        return None
    try:
        return os.path.getsize(os.path.expanduser(path))
    except OSError:
        return None


def derive_status(pid: str, exit_code: str):
    """Returns (icon, color_pair, status_text)."""
    is_running = pid not in ("-", "0", "")
    has_error = exit_code not in ("-", "0", "")
    if is_running and has_error:
        return "⚠", 3, f"exit {exit_code}"
    if is_running:
        return "●", 1, "ok"
    if has_error:
        return "✗", 2, f"exit {exit_code}"
    if exit_code == "-":
        return "○", 4, "never run"
    return "○", 4, "idle"


def collect_jobs():
    statuses = status_map()
    jobs = []
    for loc in LOCATIONS:
        if not loc.exists():
            continue
        try:
            entries = sorted(loc.glob("*.plist"))
        except PermissionError:
            continue
        is_daemon = loc == Path("/Library/LaunchDaemons")
        for p in entries:
            plist = parse_plist(p)
            if plist is None:
                continue
            label = plist.get("Label", p.stem)
            label_lc = label.lower()
            if any(sub in label_lc for sub in HIDE_LABEL_SUBSTRINGS):
                continue
            pid, code = statuses.get(label, ("-", "-"))
            icon, color, status_text = derive_status(pid, code)
            jobs.append({
                "label": label,
                "schedule": schedule_str(plist),
                "pid": pid,
                "exit": code,
                "status_text": status_text,
                "log_size": log_size(plist),
                "icon": icon,
                "color": color,
                "log_path": plist.get("StandardOutPath") or plist.get("StandardErrorPath"),
                "stderr_path": plist.get("StandardErrorPath"),
                "program": " ".join(plist.get("ProgramArguments", [])) or plist.get("Program", ""),
                "workdir": plist.get("WorkingDirectory", ""),
                "plist_path": str(p),
                "location": loc.name,
                "is_daemon": is_daemon,
            })
    return jobs


# ── launchd actions ─────────────────────────────────────────────────


def domain_for(job):
    """`gui/<uid>/<label>` for user/system agents, `system/<label>` for daemons."""
    if job["is_daemon"]:
        return f"system/{job['label']}"
    return f"gui/{os.getuid()}/{job['label']}"


def restart_job(job):
    target = domain_for(job)
    r = subprocess.run(
        ["launchctl", "kickstart", "-k", target],
        capture_output=True, text=True,
    )
    if r.returncode == 0:
        return f"Restarted {job['label']}"
    err = (r.stderr or r.stdout).strip().splitlines()[-1] if (r.stderr or r.stdout) else "unknown error"
    if job["is_daemon"]:
        err += "  (system daemons need: sudo launchctl kickstart -k " + target + ")"
    return f"Restart failed: {err}"


def stop_job(job):
    target = domain_for(job)
    r = subprocess.run(
        ["launchctl", "kill", "SIGTERM", target],
        capture_output=True, text=True,
    )
    if r.returncode == 0:
        return f"Sent SIGTERM to {job['label']}"
    err = (r.stderr or r.stdout).strip().splitlines()[-1] if (r.stderr or r.stdout) else "unknown error"
    return f"Stop failed: {err}"


