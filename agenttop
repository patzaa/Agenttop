def edit_filter(stdscr, current):
    h, _w = stdscr.getmaxyx()
    curses.curs_set(1)
    buf = current
    while True:
        stdscr.move(h - 1, 0)
        stdscr.clrtoeol()
        prompt = f"/{buf}"
        safe_addstr(stdscr, h - 1, 0, prompt, 0)
        try:
            stdscr.move(h - 1, min(len(prompt), stdscr.getmaxyx()[1] - 1))
        except curses.error:
            pass
        stdscr.refresh()
        ch = stdscr.getch()
        if ch == 27:  # ESC
            curses.curs_set(0)
            return None
        if ch in (10, 13):  # Enter
            curses.curs_set(0)
            return buf
        if ch in (curses.KEY_BACKSPACE, 127, 8):
            buf = buf[:-1]
        elif 32 <= ch < 127:
            buf += chr(ch)


def tail_log(stdscr, job):
    """Live-follow a launchd job's log file. Any key returns."""
    log = job.get("log_path")
    stderr = job.get("stderr_path")
    log_path = os.path.expanduser(log) if log else None
    stderr_path = os.path.expanduser(stderr) if stderr and stderr != log else None

    if not log_path and not stderr_path:
        stdscr.erase()
        safe_addstr(stdscr, 0, 0, f"Log peek — {job['label']}", curses.A_BOLD)
        safe_addstr(stdscr, 2, 0, "(no log path configured in plist)", curses.A_DIM)
        safe_addstr(stdscr, 4, 0, "press any key to return", curses.A_DIM)
        stdscr.refresh()
        stdscr.timeout(-1)
        stdscr.getch()
        stdscr.timeout(2000)
        return

    files = {}
    for p in (log_path, stderr_path):
        if p:
            files[p] = None

    def open_or_seek(path, prev_handle):
        try:
            new_size = os.path.getsize(path)
        except OSError:
            return None, 0
        if prev_handle is None:
            f = open(path, "rb")
            f.seek(max(0, new_size - 8192))
            return f, new_size
        try:
            cur = prev_handle.tell()
        except OSError:
            cur = 0
        if new_size < cur:
            prev_handle.close()
            f = open(path, "rb")
            return f, new_size
        return prev_handle, new_size

    stdscr.erase()
    h, w = stdscr.getmaxyx()
    safe_addstr(stdscr, 0, 0, f"Live log — {job['label']}", curses.A_BOLD, w)
    paths_str = " + ".join(p for p in (log_path, stderr_path) if p)
    safe_addstr(stdscr, 1, 0, paths_str, curses.A_DIM, w)
    safe_addstr(stdscr, h - 1, 0, "any key to return", curses.A_DIM, w)
    stdscr.refresh()

    MAX_LINES = 5000
    buf = []
    handles = {}
    sizes = {}

    for p in files:
        h_, s_ = open_or_seek(p, None)
        handles[p] = h_
        sizes[p] = s_
        if h_:
            try:
                data = h_.read().decode("utf-8", errors="replace")
                if data:
                    buf.extend((p, ln) for ln in data.splitlines())
            except OSError:
                pass

    stdscr.timeout(500)
    try:
        while True:
            for p, fh in list(handles.items()):
                if fh is None:
                    nh, ns = open_or_seek(p, None)
                    handles[p], sizes[p] = nh, ns
                    fh = nh
                if fh is None:
                    continue
                try:
                    new_data = fh.read().decode("utf-8", errors="replace")
                except OSError:
                    new_data = ""
                if new_data:
                    new_lines = new_data.splitlines()
                    buf.extend((p, ln) for ln in new_lines)
            if len(buf) > MAX_LINES:
                buf = buf[-MAX_LINES:]

            stdscr.erase()
            h, w = stdscr.getmaxyx()
            safe_addstr(stdscr, 0, 0, f"Live log — {job['label']}", curses.A_BOLD, w)
            safe_addstr(stdscr, 1, 0, paths_str, curses.A_DIM, w)
            safe_addstr(stdscr, h - 1, 0, "any key to return  (following)", curses.A_DIM, w)

            visible = h - 4
            tail = buf[-visible:] if visible > 0 else []
            for i, (src, ln) in enumerate(tail):
                attr = curses.color_pair(2) if src == stderr_path else 0
                safe_addstr(stdscr, 3 + i, 0, ln, attr, w)

            stdscr.refresh()
            ch = stdscr.getch()
            if ch != -1:
                break
    finally:
        for fh in handles.values():
            if fh is not None:
                try:
                    fh.close()
                except OSError:
                    pass
        stdscr.timeout(2000)


def tail_claude_session(stdscr, index: ClaudeIndex, sid: str, project: str):
    """Live tail one Claude session — each new assistant message renders one row.

    The ClaudeIndex is shared, so periodic refresh() picks up new events
    appended to the session's JSONL file and we render the deltas.
    """
    stdscr.timeout(1000)
    seen = len(index.events)
    rows = []  # (ts, model, in, out, cc, cr)
    for ev in index.session_events(sid):
        rows.append((ev[ClaudeIndex.TS], ev[ClaudeIndex.MODEL],
                     ev[ClaudeIndex.IN], ev[ClaudeIndex.OUT],
                     ev[ClaudeIndex.CC], ev[ClaudeIndex.CR]))
    MAX_ROWS = 1000
    try:
        while True:
            stdscr.erase()
            h, w = stdscr.getmaxyx()
            safe_addstr(stdscr, 0, 0, f"Session tail — {project}/{sid[:8]}", curses.A_BOLD, w)
            safe_addstr(stdscr, 1, 0,
                        f"{len(rows)} messages   any key to return", curses.A_DIM, w)
            header = f"  {'TIME':<8} {'MODEL':<14} {'IN':>8} {'OUT':>8} {'CC':>8} {'CR':>8}"
            safe_addstr(stdscr, 3, 0, header, curses.A_UNDERLINE, w)

            visible = max(1, h - 5)
            tail = rows[-visible:]
            cumul = sum(r[2] + r[3] + r[4] + r[5] for r in rows)

            for i, (ts, model, in_, out, cc, cr) in enumerate(tail):
                t_str = datetime.fromtimestamp(ts).strftime("%H:%M:%S")
                line = (f"  {t_str:<8} {_short_model(model)[:14]:<14} "
                        f"{_fmt_tokens(in_):>8} {_fmt_tokens(out):>8} "
                        f"{_fmt_tokens(cc):>8} {_fmt_tokens(cr):>8}")
                safe_addstr(stdscr, 4 + i, 0, line, 0, w)

            footer = f"Σ {_fmt_tokens(cumul)} tokens"
            safe_addstr(stdscr, h - 1, 0, footer.ljust(w - 1), curses.A_BOLD, w)

            stdscr.refresh()
            ch = stdscr.getch()
            if ch != -1:
                break

            # Refresh the index, append new events for this session
            added = index.refresh()
            if added:
                # Only consider events appended since we entered this view
                for ev in index.events[seen:]:
                    if ev[ClaudeIndex.SID] == sid:
                        rows.append((ev[ClaudeIndex.TS], ev[ClaudeIndex.MODEL],
                                     ev[ClaudeIndex.IN], ev[ClaudeIndex.OUT],
                                     ev[ClaudeIndex.CC], ev[ClaudeIndex.CR]))
                seen = len(index.events)
                if len(rows) > MAX_ROWS:
                    rows = rows[-MAX_ROWS:]
    finally:
        stdscr.timeout(2000)


# ── main ────────────────────────────────────────────────────────────


def draw(stdscr, jobs, sel_l, scroll_l, filter_str,
         index, limits, sel_c, window_mode, focus, status_msg=""):
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    user = getpass.getuser()

    # Top header
    title = "agenttop"
    info = f"  {user}   "
    keys = "Tab focus  q quit  r refresh  f fetch"
    safe_addstr(stdscr, 0, 0, title, curses.A_BOLD, w)
    safe_addstr(stdscr, 0, len(title), info, curses.A_DIM, w)
    if w > len(title) + len(info) + len(keys) + 3:
        safe_addstr(stdscr, 0, w - len(keys) - 1, keys, curses.A_DIM, w)

    launchd_w, claude_w = _split_widths(w)
    body_top = 1
    body_h = h - body_top - 1  # leave 1 for footer

    sessions_list = []
    if claude_w == 0:
        if focus == "launchd":
            scroll_l, sel_l, _filtered = draw_launchd_pane(
                stdscr, 0, body_top, w, body_h, jobs, sel_l, scroll_l,
                filter_str, focused=True,
            )
        else:
            sel_c, sessions_list = draw_claude_pane(
                stdscr, 0, body_top, w, body_h, index, limits,
                window_mode, sel_c, focused=True,
            )
    else:
        scroll_l, sel_l, _filtered = draw_launchd_pane(
            stdscr, 0, body_top, launchd_w, body_h, jobs, sel_l, scroll_l,
            filter_str, focused=(focus == "launchd"),
        )
        for y in range(body_top, body_top + body_h):
            safe_addstr(stdscr, y, launchd_w, "│", curses.A_DIM, w)
        sel_c, sessions_list = draw_claude_pane(
            stdscr, launchd_w + 1, body_top, claude_w, body_h, index,
            limits, window_mode, sel_c, focused=(focus == "claude"),
        )

    # Footer
    footer_y = h - 1
    if status_msg:
        attr = curses.color_pair(2) | curses.A_BOLD if "fail" in status_msg.lower() \
               else curses.color_pair(1) | curses.A_BOLD
        safe_addstr(stdscr, footer_y, 0, status_msg, attr, w)
    elif filter_str and focus == "launchd":
        safe_addstr(stdscr, footer_y, 0,
                    f"filter: /{filter_str}    (c to clear)", curses.A_DIM, w)
    else:
        hint = ("[launchd] / filter  R restart  s stop  Enter tail"
                if focus == "launchd"
                else "[claude]  v window  f fetch limits  Enter session tail")
        safe_addstr(stdscr, footer_y, 0, hint, curses.A_DIM, w)

    stdscr.refresh()
    return scroll_l, sel_l, sel_c, sessions_list


def main(stdscr):
    curses.curs_set(0)
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_GREEN, -1)    # ok / running
    curses.init_pair(2, curses.COLOR_RED, -1)      # error
    curses.init_pair(3, curses.COLOR_YELLOW, -1)   # warning
    curses.init_pair(4, -1, -1)                    # idle
    curses.init_pair(5, curses.COLOR_CYAN, -1)     # focused pane title

    stdscr.timeout(2000)

    # Initial scan can take a moment on big indexes — show a splash.
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    safe_addstr(stdscr, h // 2, max(0, (w - 28) // 2),
                "scanning ~/.claude/projects…", curses.A_DIM)
    stdscr.refresh()

    index = ClaudeIndex()
    index.refresh()
    index.save()  # warm/refresh the on-disk cache (prunes internally)
    last_save = time.time()
    limits = LimitsFetcher()
    if limits.is_stale():
        limits.fetch_async()  # background; UI shows cached value or "fetching…"

    jobs = collect_jobs()
    sel_l = 0
    scroll_l = 0
    sel_c = 0
    filter_str = ""
    window_mode = "5h"
    focus = "launchd"
    status_msg = ""
    status_msg_until = 0
    tick = 0

    def current_view():
        return [j for j in jobs if filter_str.lower() in j["label"].lower()] if filter_str else jobs

    while True:
        scroll_l, sel_l, sel_c, sessions_list = draw(
            stdscr, jobs, sel_l, scroll_l, filter_str,
            index, limits, sel_c, window_mode, focus, status_msg,
        )
        ch = stdscr.getch()
        tick += 1
        if status_msg and tick > status_msg_until:
            status_msg = ""
        if ch == -1:
            jobs = collect_jobs()
            added = index.refresh()
            if limits.is_stale():
                limits.fetch_async()
            if added and time.time() - last_save > SAVE_INTERVAL_SECONDS:
                index.save()
                last_save = time.time()
            continue

        # Global keys
        if ch in (ord('q'), ord('Q')):
            index.save()
            break
        if ch == 9:  # Tab
            focus = "claude" if focus == "launchd" else "launchd"
            continue
        if ch == ord('r'):
            jobs = collect_jobs()
            index.refresh()
            status_msg = "Refreshed"
            status_msg_until = tick + 2
            continue
        if ch == ord('f'):
            limits.fetch_async()
            status_msg = "Fetching Anthropic limits…"
            status_msg_until = tick + 4
            continue

        # Pane-specific keys
        if focus == "launchd":
            if ch == ord('/'):
                new = edit_filter(stdscr, filter_str)
                if new is not None:
                    filter_str = new
                    sel_l = 0
                    scroll_l = 0
            elif ch == ord('c'):
                filter_str = ""
                sel_l = 0
                scroll_l = 0
            elif ch in (curses.KEY_DOWN, ord('j')):
                sel_l += 1
            elif ch in (curses.KEY_UP, ord('k')):
                sel_l = max(0, sel_l - 1)
            elif ch == ord('g'):
                sel_l = 0
                scroll_l = 0
            elif ch == ord('G'):
                sel_l = len(jobs) - 1
            elif ch == ord('R'):
                view = current_view()
                if 0 <= sel_l < len(view):
                    status_msg = restart_job(view[sel_l])
                    status_msg_until = tick + 4
                    jobs = collect_jobs()
            elif ch == ord('s'):
                view = current_view()
                if 0 <= sel_l < len(view):
                    status_msg = stop_job(view[sel_l])
                    status_msg_until = tick + 4
                    jobs = collect_jobs()
            elif ch in (10, 13):
                view = current_view()
                if 0 <= sel_l < len(view):
                    tail_log(stdscr, view[sel_l])
        else:  # focus == "claude"
            if ch in (curses.KEY_DOWN, ord('j')):
                sel_c += 1
            elif ch in (curses.KEY_UP, ord('k')):
                sel_c = max(0, sel_c - 1)
            elif ch == ord('v'):
                modes = [m for m, _ in WINDOW_MODES]
                window_mode = modes[(modes.index(window_mode) + 1) % len(modes)]
            elif ch in (10, 13):
                if 0 <= sel_c < len(sessions_list):
                    sid, info = sessions_list[sel_c]
                    tail_claude_session(stdscr, index, sid, info["project"])


# ── entrypoint ──────────────────────────────────────────────────────


def _once_launchd():
    for j in collect_jobs():
        print(f"{j['icon']} {j['label']:<50} {j['schedule']:<22} pid={j['pid']:<6} {j['status_text']:<14} log={human_size(j['log_size'])}")


def _once_claude():
    idx = ClaudeIndex()
    idx.refresh()
    idx.save()  # warm/refresh the shared on-disk cache
    now = datetime.now().timestamp()
    agg = idx.aggregate(since=now - 5 * 3600, until=now)
    t = agg["totals"]
    print("=== Anthropic real rate-limit headers ===")
    fetch_arg = "--no-fetch" not in sys.argv
    if fetch_arg:
        print("(making one tiny `claude -p .` call to read headers — costs 1 message)")
        ld = fetch_anthropic_limits()
        if ld and "error" not in ld:
            try:
                LIMITS_CACHE.parent.mkdir(parents=True, exist_ok=True)
                LIMITS_CACHE.write_text(json.dumps(ld))
            except OSError:
                pass
    else:
        try:
            ld = json.loads(LIMITS_CACHE.read_text())
            age = int(time.time() - ld.get("ts", 0))
            print(f"(using cached headers, {age}s old; pass --fetch to refresh)")
        except (OSError, json.JSONDecodeError):
            ld = {}
    if "error" in ld:
        print(f"  error: {ld['error']}")
    elif ld:
        for k in ("5h", "7d"):
            u = ld.get(f"{k}_util")
            r = ld.get(f"{k}_reset")
            s = ld.get(f"{k}_status")
            if u is not None:
                reset_str = (datetime.fromtimestamp(r).strftime("%a %d %H:%M")
                             if r else "?")
                print(f"  {k}: {u * 100:5.1f}% used  status={s}  resets at {reset_str}")
        print(f"  overall status: {ld.get('status')}  "
              f"representative claim: {ld.get('representative')}")
    print()
    print(f"=== Local activity (last 5h, from ~/.claude/projects/*.jsonl) ===")
    print(f"sessions: {len(agg['by_session'])}   messages: {t['msgs']}")
    print(f"in {_fmt_tokens(t['in_'])}  out {_fmt_tokens(t['out'])}  "
          f"cc {_fmt_tokens(t['cc'])}  cr {_fmt_tokens(t['cr'])}  "
          f"Σ {_fmt_tokens(total_tokens(t))}")
    print()
    print("By model:")
    for m, b in sorted(agg["by_model"].items(), key=lambda kv: -total_tokens(kv[1])):
        print(f"  {_short_model(m):<16} Σ {_fmt_tokens(total_tokens(b)):>8}  msgs {b['msgs']}")
    print()
    print("Active sessions (branch / model / last / tokens):")
    sess_sorted = sorted(agg["by_session"].items(), key=lambda kv: -kv[1]["last"])
    for sid, b in sess_sorted[:10]:
        sm = idx.session_meta.get(sid, {})
        branch = sm.get("branch") or os.path.basename(sm.get("cwd") or "") or b["project"]
        print(f"  {_short_branch(branch, 32):<32} {_short_model(b['model']):<14} "
              f"{_fmt_relative(b['last'], now):<10} Σ {_fmt_tokens(total_tokens(b)):>8}  {sid[:6]}")
    print()
    print("Last 24h — peak tokens/min per hour:")
    peaks = idx.hourly_peaks(now, hours=24)
    in_vals = [p["max_in"] for p in peaks]
    out_vals = [p["max_out"] for p in peaks]
    in_max = max(in_vals) if in_vals else 0
    out_max = max(out_vals) if out_vals else 0
    print(f"  in   {_sparkline(in_vals, in_max)}    peak {_fmt_tokens(in_max)}")
    print(f"  out  {_sparkline(out_vals, out_max)}    peak {_fmt_tokens(out_max)}")
    if peaks:
        t0 = datetime.fromtimestamp(peaks[0]["hour_ts"]).strftime("%H:%M")
        tn = datetime.fromtimestamp(peaks[-1]["hour_ts"]).strftime("%H:%M")
        print(f"       {t0}{' ' * 18}{tn}")


if __name__ == "__main__":
    if "--once" in sys.argv:
        _once_launchd()
        sys.exit(0)
    if "--once-claude" in sys.argv:
        _once_claude()
        sys.exit(0)
    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        pass
