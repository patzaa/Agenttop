def edit_filter(stdscr, current):
    h, _w = stdscr.getmaxyx()
    curses.curs_set(1)
    buf = current
    while True:
        stdscr.move(h - 1, 0)
        stdscr.clrtoeol()
        prompt = f"/{buf}"
        safe_addstr(stdscr, h - 1, 0, prompt, 0)
        try:
            stdscr.move(h - 1, min(len(prompt), stdscr.getmaxyx()[1] - 1))
        except curses.error:
            pass
        stdscr.refresh()
        ch = stdscr.getch()
        if ch == 27:  # ESC
            curses.curs_set(0)
            return None
        if ch in (10, 13):  # Enter
            curses.curs_set(0)
            return buf
        if ch in (curses.KEY_BACKSPACE, 127, 8):
            buf = buf[:-1]
        elif 32 <= ch < 127:
            buf += chr(ch)


def tail_log(stdscr, job):
    """Live-follow a launchd job's log file. Any key returns."""
    log = job.get("log_path")
    stderr = job.get("stderr_path")
    log_path = os.path.expanduser(log) if log else None
    stderr_path = os.path.expanduser(stderr) if stderr and stderr != log else None

    if not log_path and not stderr_path:
        stdscr.erase()
        safe_addstr(stdscr, 0, 0, f"Log peek — {job['label']}", curses.A_BOLD)
        safe_addstr(stdscr, 2, 0, "(no log path configured in plist)", curses.A_DIM)
        safe_addstr(stdscr, 4, 0, "press any key to return", curses.A_DIM)
        stdscr.refresh()
        stdscr.timeout(-1)
        stdscr.getch()
        stdscr.timeout(2000)
        return

    files = {}
    for p in (log_path, stderr_path):
        if p:
            files[p] = None

    def open_or_seek(path, prev_handle):
        try:
            new_size = os.path.getsize(path)
        except OSError:
            return None, 0
        if prev_handle is None:
            f = open(path, "rb")
            f.seek(max(0, new_size - 8192))
            return f, new_size
        try:
            cur = prev_handle.tell()
        except OSError:
            cur = 0
        if new_size < cur:
            prev_handle.close()
            f = open(path, "rb")
            return f, new_size
        return prev_handle, new_size

    stdscr.erase()
    h, w = stdscr.getmaxyx()
    safe_addstr(stdscr, 0, 0, f"Live log — {job['label']}", curses.A_BOLD, w)
    paths_str = " + ".join(p for p in (log_path, stderr_path) if p)
    safe_addstr(stdscr, 1, 0, paths_str, curses.A_DIM, w)
    safe_addstr(stdscr, h - 1, 0, "any key to return", curses.A_DIM, w)
    stdscr.refresh()

    MAX_LINES = 5000
    buf = []
    handles = {}
    sizes = {}

    for p in files:
        h_, s_ = open_or_seek(p, None)
        handles[p] = h_
        sizes[p] = s_
        if h_:
            try:
                data = h_.read().decode("utf-8", errors="replace")
                if data:
                    buf.extend((p, ln) for ln in data.splitlines())
            except OSError:
                pass

    stdscr.timeout(500)
    try:
        while True:
            for p, fh in list(handles.items()):
                if fh is None:
                    nh, ns = open_or_seek(p, None)
                    handles[p], sizes[p] = nh, ns
                    fh = nh
                if fh is None:
                    continue
                try:
                    new_data = fh.read().decode("utf-8", errors="replace")
                except OSError:
                    new_data = ""
                if new_data:
                    new_lines = new_data.splitlines()
                    buf.extend((p, ln) for ln in new_lines)
            if len(buf) > MAX_LINES:
                buf = buf[-MAX_LINES:]

            stdscr.erase()
            h, w = stdscr.getmaxyx()
            safe_addstr(stdscr, 0, 0, f"Live log — {job['label']}", curses.A_BOLD, w)
            safe_addstr(stdscr, 1, 0, paths_str, curses.A_DIM, w)
            safe_addstr(stdscr, h - 1, 0, "any key to return  (following)", curses.A_DIM, w)

            visible = h - 4
            tail = buf[-visible:] if visible > 0 else []
            for i, (src, ln) in enumerate(tail):
                attr = curses.color_pair(2) if src == stderr_path else 0
                safe_addstr(stdscr, 3 + i, 0, ln, attr, w)

            stdscr.refresh()
            ch = stdscr.getch()
            if ch != -1:
                break
    finally:
        for fh in handles.values():
            if fh is not None:
                try:
                    fh.close()
                except OSError:
                    pass
        stdscr.timeout(2000)


def tail_claude_session(stdscr, index: ClaudeIndex, sid: str, project: str):
    """Live tail one Claude session — one row per active MINUTE.

    The ClaudeIndex is shared, so periodic refresh() grows the session's
    minute buckets and we simply re-derive the rows (the scan is tiny in v2);
    the current minute's row updates in place as tokens accumulate.
    """
    stdscr.timeout(1000)

    def build_rows():
        return [(ev[ClaudeIndex.TS], ev[ClaudeIndex.MODEL],
                 ev[ClaudeIndex.IN], ev[ClaudeIndex.OUT],
                 ev[ClaudeIndex.CC], ev[ClaudeIndex.CR])
                for ev in index.session_events(sid)]

    rows = build_rows()
    MAX_ROWS = 1000
    try:
        while True:
            stdscr.erase()
            h, w = stdscr.getmaxyx()
            safe_addstr(stdscr, 0, 0, f"Session tail — {project}/{sid[:8]}", curses.A_BOLD, w)
            safe_addstr(stdscr, 1, 0,
                        f"{len(rows)} active minutes   any key to return", curses.A_DIM, w)
            header = f"  {'TIME':<8} {'MODEL':<14} {'IN':>8} {'OUT':>8} {'CC':>8} {'CR':>8}"
            safe_addstr(stdscr, 3, 0, header, curses.A_UNDERLINE, w)

            visible = max(1, h - 5)
            tail = rows[-visible:]
            cumul = sum(r[2] + r[3] + r[4] + r[5] for r in rows)

            for i, (ts, model, in_, out, cc, cr) in enumerate(tail):
                t_str = datetime.fromtimestamp(ts).strftime("%H:%M:%S")
                line = (f"  {t_str:<8} {_short_model(model)[:14]:<14} "
                        f"{_fmt_tokens(in_):>8} {_fmt_tokens(out):>8} "
                        f"{_fmt_tokens(cc):>8} {_fmt_tokens(cr):>8}")
                safe_addstr(stdscr, 4 + i, 0, line, 0, w)

            footer = f"Σ {_fmt_tokens(cumul)} tokens"
            safe_addstr(stdscr, h - 1, 0, footer.ljust(w - 1), curses.A_BOLD, w)

            stdscr.refresh()
            ch = stdscr.getch()
            if ch != -1:
                break

            # Refresh the index; re-derive this session's minute rows (cheap in v2)
            if index.refresh():
                rows = build_rows()
                if len(rows) > MAX_ROWS:
                    rows = rows[-MAX_ROWS:]
    finally:
        stdscr.timeout(2000)


