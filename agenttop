def draw_launchd_pane(stdscr, x0, y0, w, h, all_jobs, selected, scroll,
                      filter_str, focused: bool):
    """Renders the launchd pane within rectangle (x0, y0, w, h).
    Returns adjusted (scroll, selected, filtered_jobs).
    """
    if filter_str:
        jobs = [j for j in all_jobs if filter_str.lower() in j["label"].lower()]
    else:
        jobs = all_jobs

    running = sum(1 for j in jobs if j["pid"] not in ("-", "0", ""))
    failed = sum(1 for j in jobs if j["exit"] not in ("-", "0", ""))

    # Title
    # B2: Fokus traegt das GEWICHT, nicht die Farbe — unfokussiert wird gedimmt.
    title_attr = curses.A_BOLD if focused else (curses.A_BOLD | curses.A_DIM)
    title = "LAUNCHD"
    info = f"  {len(jobs)} jobs ({running} ok, {failed} fail)"
    safe_addstr(stdscr, y0, x0, title, title_attr, x0 + w)
    safe_addstr(stdscr, y0, x0 + len(title), info, 0, x0 + w)

    # Compressed columns when split, full when full-width
    compact = w < 110
    if compact:
        header = f" {'LABEL':<32} {'SCHEDULE':<14} {'PID':<6} {'STATUS':<10} {'LOG':>6}"
    else:
        header = f"{'STATUS':<7} {'LABEL':<48} {'SCHEDULE':<20} {'PID':<7} {'LAST EXIT':<11} LOG"
    safe_addstr(stdscr, y0 + 2, x0, header, curses.A_BOLD | curses.A_UNDERLINE, x0 + w)

    # Clamp selection
    if selected >= len(jobs):
        selected = max(0, len(jobs) - 1)
    if selected < 0:
        selected = 0

    body_top = y0 + 3
    body_h = h - 3 - 1  # leave 1 for footer

    if selected < scroll:
        scroll = selected
    elif selected >= scroll + body_h:
        scroll = selected - body_h + 1
    if scroll < 0:
        scroll = 0

    for i, j in enumerate(jobs[scroll:scroll + body_h]):
        y = body_top + i
        is_sel = focused and (scroll + i == selected)
        sel_attr = curses.A_REVERSE if is_sel else 0
        color_attr = curses.color_pair(j["color"])
        if j["color"] == 4:
            color_attr |= curses.A_DIM

        # Fleet mode sets "display" (label minus the com.hausverwaltung./… prefix)
        # — the prefix is noise in the list; the full label lives in the detail pane.
        shown = j.get("display") or j["label"]
        if compact:
            label = shown[:29]
            schedule = j["schedule"][:13]
            pid = j["pid"][:5]
            status_text = j["status_text"][:9]
            log_str = human_size(j["log_size"])
            row = f" {j['icon']}  {label:<29} {schedule:<14} {pid:<6} {status_text:<10} {log_str:>6}"
            safe_addstr(stdscr, y, x0, row.ljust(w), sel_attr | color_attr, x0 + w)
        else:
            label = shown[:47]
            schedule = j["schedule"][:19]
            pid = j["pid"][:6]
            status_text = j["status_text"][:10]
            log_str = human_size(j["log_size"])
            row = f" {j['icon']}     {label:<48} {schedule:<20} {pid:<7} {status_text:<11} {log_str:>5}"
            row = row.ljust(w)
            safe_addstr(stdscr, y, x0, row, sel_attr | color_attr, x0 + w)

    return scroll, selected, jobs


