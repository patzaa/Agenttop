#!/usr/bin/env python3
"""agenttop — TUI for launchd jobs + Claude Code usage (htop-style).

Two-pane vertical split:
  Left  — launchd jobs from ~/Library/LaunchAgents, /Library/LaunchAgents,
          /Library/LaunchDaemons.
  Right — Claude Code usage from ~/.claude/projects/**/*.jsonl
          5h rolling window, per-model + per-project breakdown, active
          sessions, 7-day history. Per-session live tail.

Auto-refreshes every 2s. Zero deps — Python stdlib (curses + json).

Global keys:
  q / Q     quit
  Tab       cycle pane focus
  r         force refresh

Left pane (launchd) — keys active when focused:
  / (slash) filter (Enter to apply, Esc to cancel)    c clear filter
  j / ↓     down                                       k / ↑   up
  g / G     top / bottom
  Enter     follow log live (any key returns)
  R         restart selected job (kickstart -k)
  s         stop selected job (SIGTERM)

Right pane (Claude) — keys active when focused:
  j / ↓     down                                       k / ↑   up
  Enter     tail selected session (live token stream)
  v         cycle window: 5h → today → 7d → 5h
"""

import curses
import getpass
import json
import os
import pickle
import re
import subprocess
import sys
import threading
import time
from collections import defaultdict
from datetime import datetime, timedelta
from pathlib import Path

WEEKDAYS = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"]

LOCATIONS = [
    Path.home() / "Library" / "LaunchAgents",
    Path("/Library/LaunchAgents"),
    Path("/Library/LaunchDaemons"),
]

CLAUDE_DIR = Path.home() / ".claude" / "projects"

HIDE_LABEL_SUBSTRINGS = (
    "adobe",
    "grammarly",
    "onedrive",
)

WINDOW_MODES = [("5h", 5 * 3600), ("today", "today"), ("7d", 7 * 86400)]

CACHE_DIR = Path.home() / ".cache" / "agenttop"
LIMITS_CACHE = CACHE_DIR / "anthropic-limits.json"
LEGACY_CACHE = Path.home() / ".cache" / "launchd-top" / "anthropic-limits.json"
LIMITS_TTL_SECONDS = 3600  # auto-refresh after 1h of staleness (≈1 msg/h while running)

# Persistent event index — avoids re-parsing all of ~/.claude/projects (590MB+,
# millions of lines) on every cold start. Parse once, reload in <1s thereafter.
INDEX_CACHE = CACHE_DIR / "index-cache.pkl"
INDEX_CACHE_VERSION = 1            # bump to invalidate cache on schema change
EVENT_RETENTION_DAYS = 31         # drop events older than this; no view looks back further
SAVE_INTERVAL_SECONDS = 120       # throttle on-disk index writes while running


def fetch_anthropic_limits() -> dict:
    """Fetch real anthropic-ratelimit-* headers by running a tiny `claude -p .` call.

    The headers come from Anthropic's API response, parsed verbatim — no math
    or estimation on this side. Each call costs one billable message, so callers
    must rate-limit (this is the raw fetch; caching is in LimitsFetcher).
    """
    env = {**os.environ, "ANTHROPIC_LOG": "debug"}
    try:
        r = subprocess.run(
            ["claude", "--no-session-persistence", "-p", "."],
            capture_output=True, text=True, timeout=60, env=env,
        )
    except (subprocess.TimeoutExpired, FileNotFoundError) as e:
        return {"error": f"claude call failed: {e}", "ts": time.time()}

    text = r.stdout + r.stderr
    pat = re.compile(r'"(anthropic-ratelimit-[a-z0-9-]+)":\s*"([^"]+)"')
    headers = {}
    for k, v in pat.findall(text):
        headers[k] = v

    if not headers:
        return {
            "error": "no anthropic-ratelimit-* headers in response",
            "ts": time.time(),
        }

    def gf(k):
        try: return float(headers[k])
        except (KeyError, ValueError): return None
    def gi(k):
        try: return int(headers[k])
        except (KeyError, ValueError): return None

    return {
        "ts": time.time(),
        "5h_util": gf("anthropic-ratelimit-unified-5h-utilization"),
        "5h_reset": gi("anthropic-ratelimit-unified-5h-reset"),
        "5h_status": headers.get("anthropic-ratelimit-unified-5h-status"),
        "7d_util": gf("anthropic-ratelimit-unified-7d-utilization"),
        "7d_reset": gi("anthropic-ratelimit-unified-7d-reset"),
        "7d_status": headers.get("anthropic-ratelimit-unified-7d-status"),
        "status": headers.get("anthropic-ratelimit-unified-status"),
        "representative": headers.get("anthropic-ratelimit-unified-representative-claim"),
    }


class LimitsFetcher:
    """Caches Anthropic rate-limit headers; refreshes async on demand.

    State lives in ~/.cache/launchd-top/anthropic-limits.json so cache survives
    restarts. Background thread fetches; main loop reads `data` cheaply.
    """

    def __init__(self):
        self.data: dict = {}
        self.fetching: bool = False
        self.lock = threading.Lock()
        self._load_cache()

    def _load_cache(self):
        for path in (LIMITS_CACHE, LEGACY_CACHE):
            try:
                self.data = json.loads(path.read_text())
                return
            except (OSError, json.JSONDecodeError):
                continue
        self.data = {}

    def age_seconds(self) -> float:
        ts = (self.data or {}).get("ts", 0)
        return max(0, time.time() - ts) if ts else float("inf")

    def is_stale(self, ttl: int = LIMITS_TTL_SECONDS) -> bool:
        if not self.data or "error" in self.data:
            return True
        return self.age_seconds() > ttl

    def fetch_async(self):
        with self.lock:
            if self.fetching:
                return
            self.fetching = True
        t = threading.Thread(target=self._fetch_blocking, daemon=True)
        t.start()

    def _fetch_blocking(self):
        try:
            result = fetch_anthropic_limits()
            with self.lock:
                self.data = result
            try:
                LIMITS_CACHE.parent.mkdir(parents=True, exist_ok=True)
                LIMITS_CACHE.write_text(json.dumps(result))
            except OSError:
                pass
        finally:
            with self.lock:
                self.fetching = False

# ── launchd data layer ──────────────────────────────────────────────


def parse_plist(path: Path):
    r = subprocess.run(
        ["plutil", "-convert", "json", "-o", "-", str(path)],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        return None
    try:
        return json.loads(r.stdout)
    except json.JSONDecodeError:
        return None


def schedule_str(plist: dict) -> str:
    if "StartCalendarInterval" in plist:
        sci = plist["StartCalendarInterval"]
        if isinstance(sci, dict):
            sci = [sci]
        parts = []
        for d in sci:
            day = WEEKDAYS[d["Weekday"] % 7] if "Weekday" in d else "*"
            hour = d.get("Hour")
            mn = d.get("Minute", 0)
            time = f"{hour:02d}:{mn:02d}" if hour is not None else "*"
            parts.append(f"{day} {time}")
        if len(parts) > 1:
            times = {p.split(" ", 1)[1] for p in parts}
            if len(times) == 1:
                days = ",".join(p.split(" ", 1)[0] for p in parts)
                return f"{days} {times.pop()}"
        return ", ".join(parts)
    if "StartInterval" in plist:
        s = plist["StartInterval"]
        for unit, n in (("d", 86400), ("h", 3600), ("m", 60)):
            if s >= n and s % n == 0:
                return f"every {s // n}{unit}"
        return f"every {s}s"
    if plist.get("KeepAlive"):
        return "keep-alive"
    if plist.get("RunAtLoad"):
        return "at load"
    if "WatchPaths" in plist:
        return "on path change"
    return "-"


def status_map() -> dict:
    r = subprocess.run(["launchctl", "list"], capture_output=True, text=True)
    s = {}
    for line in r.stdout.splitlines()[1:]:
        parts = line.split(None, 2)
        if len(parts) == 3:
            pid, code, label = parts
            s[label] = (pid, code)
    return s


def human_size(n):
    if n is None:
        return "-"
    if n < 1024:
        return f"{n}B"
    if n < 1024 * 1024:
        return f"{n // 1024}K"
    if n < 1024 ** 3:
        return f"{n / (1024 ** 2):.1f}M"
    return f"{n / (1024 ** 3):.1f}G"


def log_size(plist: dict):
    path = plist.get("StandardOutPath") or plist.get("StandardErrorPath")
    if not path:
        return None
    try:
        return os.path.getsize(os.path.expanduser(path))
    except OSError:
        return None


def derive_status(pid: str, exit_code: str):
    """Returns (icon, color_pair, status_text)."""
    is_running = pid not in ("-", "0", "")
    has_error = exit_code not in ("-", "0", "")
    if is_running and has_error:
        return "⚠", 3, f"exit {exit_code}"
    if is_running:
        return "●", 1, "ok"
    if has_error:
        return "✗", 2, f"exit {exit_code}"
    if exit_code == "-":
        return "○", 4, "never run"
    return "○", 4, "idle"


def collect_jobs():
    statuses = status_map()
    jobs = []
    for loc in LOCATIONS:
        if not loc.exists():
            continue
        try:
            entries = sorted(loc.glob("*.plist"))
        except PermissionError:
            continue
        is_daemon = loc == Path("/Library/LaunchDaemons")
        for p in entries:
            plist = parse_plist(p)
            if plist is None:
                continue
            label = plist.get("Label", p.stem)
            label_lc = label.lower()
            if any(sub in label_lc for sub in HIDE_LABEL_SUBSTRINGS):
                continue
            pid, code = statuses.get(label, ("-", "-"))
            icon, color, status_text = derive_status(pid, code)
            jobs.append({
                "label": label,
                "schedule": schedule_str(plist),
                "pid": pid,
                "exit": code,
                "status_text": status_text,
                "log_size": log_size(plist),
                "icon": icon,
                "color": color,
                "log_path": plist.get("StandardOutPath") or plist.get("StandardErrorPath"),
                "stderr_path": plist.get("StandardErrorPath"),
                "location": loc.name,
                "is_daemon": is_daemon,
            })
    return jobs


# ── launchd actions ─────────────────────────────────────────────────


def domain_for(job):
    """`gui/<uid>/<label>` for user/system agents, `system/<label>` for daemons."""
    if job["is_daemon"]:
        return f"system/{job['label']}"
    return f"gui/{os.getuid()}/{job['label']}"


def restart_job(job):
    target = domain_for(job)
    r = subprocess.run(
        ["launchctl", "kickstart", "-k", target],
        capture_output=True, text=True,
    )
    if r.returncode == 0:
        return f"Restarted {job['label']}"
    err = (r.stderr or r.stdout).strip().splitlines()[-1] if (r.stderr or r.stdout) else "unknown error"
    if job["is_daemon"]:
        err += "  (system daemons need: sudo launchctl kickstart -k " + target + ")"
    return f"Restart failed: {err}"


def stop_job(job):
    target = domain_for(job)
    r = subprocess.run(
        ["launchctl", "kill", "SIGTERM", target],
        capture_output=True, text=True,
    )
    if r.returncode == 0:
        return f"Sent SIGTERM to {job['label']}"
    err = (r.stderr or r.stdout).strip().splitlines()[-1] if (r.stderr or r.stdout) else "unknown error"
    return f"Stop failed: {err}"


# ── Claude data layer ───────────────────────────────────────────────


def _iso_to_epoch(s: str) -> float:
    """Parse ISO-8601 to UNIX epoch. Accepts trailing Z or +00:00."""
    if s.endswith("Z"):
        s = s[:-1] + "+00:00"
    return datetime.fromisoformat(s).timestamp()


def _short_model(model: str) -> str:
    """claude-opus-4-7 → opus-4.7, claude-sonnet-4-6 → sonnet-4.6."""
    if not model:
        return "?"
    m = model
    if m.startswith("claude-"):
        m = m[len("claude-"):]
    # claude-haiku-4-5-20251001 → haiku-4-5 (drop date suffix)
    parts = m.split("-")
    keep = []
    for p in parts:
        # Drop date-shaped tokens (8 digits)
        if p.isdigit() and len(p) == 8:
            break
        keep.append(p)
    out = "-".join(keep)
    # opus-4-7 → opus-4.7 (more compact + readable)
    if len(keep) >= 3 and keep[-1].isdigit() and keep[-2].isdigit():
        out = "-".join(keep[:-2]) + "-" + keep[-2] + "." + keep[-1]
    return out


def _project_name_from_dir(d: Path) -> str:
    """Best-effort: read a cwd from any event in this dir; else last segment of dir name."""
    try:
        for jsonl in sorted(d.glob("*.jsonl")):
            try:
                with open(jsonl, "rb") as f:
                    for raw in f:
                        try:
                            ev = json.loads(raw)
                        except (json.JSONDecodeError, ValueError):
                            continue
                        cwd = ev.get("cwd")
                        if cwd:
                            base = os.path.basename(cwd)
                            if base:
                                return base
                    break  # only inspect first file
            except OSError:
                continue
    except OSError:
        pass
    name = d.name.lstrip("-")
    parts = name.split("-")
    return parts[-1] if parts else name or "?"


def _fmt_tokens(n: int) -> str:
    if n is None:
        return "-"
    if n < 1000:
        return str(n)
    if n < 1_000_000:
        return f"{n / 1000:.1f}K".replace(".0K", "K")
    if n < 1_000_000_000:
        return f"{n / 1_000_000:.1f}M".replace(".0M", "M")
    return f"{n / 1_000_000_000:.1f}G"


def _fmt_relative(ts: float, now: float) -> str:
    delta = max(0, int(now - ts))
    if delta < 60:
        return f"{delta}s ago"
    if delta < 3600:
        return f"{delta // 60}m ago"
    if delta < 86400:
        return f"{delta // 3600}h ago"
    return f"{delta // 86400}d ago"


def _fmt_duration(minutes: float) -> str:
    if minutes <= 0:
        return "now"
    if minutes >= 1440:
        return f"{int(minutes / 1440)}d"
    if minutes >= 60:
        h, m = divmod(int(minutes), 60)
        return f"{h}h {m}m" if m else f"{h}h"
    return f"{int(minutes)}m"


def _short_branch(b: str, max_len: int = 22) -> str:
    if not b:
        return ""
    if len(b) <= max_len:
        return b
    return b[: max_len - 1] + "…"


def _sparkline(values, max_val=None) -> str:
    """One-row sparkline using Unicode block heights (▁▂▃▄▅▆▇█)."""
    if not values:
        return ""
    blocks = " ▁▂▃▄▅▆▇█"
    m = max_val if max_val is not None else max(values)
    if not m:
        return blocks[0] * len(values)
    chars = []
    for v in values:
        idx = max(0, min(len(blocks) - 1, int((v / m) * (len(blocks) - 1))))
        chars.append(blocks[idx])
    return "".join(chars)


def _bar(frac: float, width: int) -> str:
    """Unicode block bar — full + partial blocks."""
    if width <= 0:
        return ""
    frac = max(0.0, min(1.0, frac))
    blocks = " ▏▎▍▌▋▊▉█"
    units = frac * width
    full = int(units)
    rem = units - full
    partial = blocks[int(rem * (len(blocks) - 1))]
    s = "█" * full + (partial if full < width else "")
    return s.ljust(width, "·")


class ClaudeIndex:
    """Incremental scan of ~/.claude/projects/**/*.jsonl.

    On refresh(): re-stats every file, only reads newly-appended bytes.
    Events stay in memory as flat tuples — small (~64 bytes each), so 100k+
    events fit easily.
    """

    # Event tuple positions
    TS, PROJECT, SID, MODEL, IN, OUT, CC, CR = range(8)

    def __init__(self, root: Path = None):
        self.root = root or CLAUDE_DIR
        self.files: dict = {}     # path -> {pos, project}
        self.events: list = []    # (ts, project, sid, model, in, out, cc, cr)
        self.project_names: dict = {}  # project_dir -> display name
        # Per-session side data (latest seen). Updated as new events parse.
        self.session_meta: dict = {}   # sid -> {branch, cwd, project, model, last_ts}
        self.errors: int = 0      # count of malformed lines
        self._load_index()

    def _load_index(self):
        """Restore the parsed index from disk, if present and current.

        On success, refresh() resumes from each file's saved byte offset and
        only reads appended data — a cold start drops from ~minutes to <1s.
        Any error (missing/corrupt cache, version bump) silently falls back to
        an empty index, forcing a one-time full rescan.
        """
        try:
            with open(INDEX_CACHE, "rb") as f:
                blob = pickle.load(f)
        except (OSError, pickle.UnpicklingError, EOFError, ValueError):
            return
        if not isinstance(blob, dict) or blob.get("version") != INDEX_CACHE_VERSION:
            return
        try:
            self.files = {Path(k): v for k, v in blob["files"].items()}
            self.events = blob["events"]
            self.project_names = {Path(k): v for k, v in blob["project_names"].items()}
            self.session_meta = blob["session_meta"]
            self.errors = blob.get("errors", 0)
        except (KeyError, TypeError, AttributeError):
            self.files, self.events = {}, []
            self.project_names, self.session_meta, self.errors = {}, {}, 0

    def prune(self, now: float = None, days: int = EVENT_RETENTION_DAYS):
        """Drop in-memory events older than the retention window.

        File offsets are left untouched, so pruned-away history is never
        re-read — it's simply outside every view's lookback. Keeps both memory
        and the on-disk cache bounded as history grows.
        """
        now = now if now is not None else time.time()
        cutoff = now - days * 86400
        if self.events:
            self.events = [e for e in self.events if e[self.TS] >= cutoff]

    def save(self):
        """Atomically persist the index (prunes first to bound size)."""
        self.prune()
        try:
            CACHE_DIR.mkdir(parents=True, exist_ok=True)
            blob = {
                "version": INDEX_CACHE_VERSION,
                "files": {str(k): v for k, v in self.files.items()},
                "events": self.events,
                "project_names": {str(k): v for k, v in self.project_names.items()},
                "session_meta": self.session_meta,
                "errors": self.errors,
            }
            tmp = INDEX_CACHE.parent / (INDEX_CACHE.name + ".tmp")
            with open(tmp, "wb") as f:
                pickle.dump(blob, f, protocol=5)
            os.replace(tmp, INDEX_CACHE)
        except (OSError, pickle.PicklingError):
            pass

    def _project_name(self, project_dir: Path) -> str:
        if project_dir not in self.project_names:
            self.project_names[project_dir] = _project_name_from_dir(project_dir)
        return self.project_names[project_dir]

    def refresh(self) -> int:
        """Returns number of new events added."""
        if not self.root.exists():
            return 0
        try:
            project_dirs = [p for p in self.root.iterdir() if p.is_dir()]
        except OSError:
            return 0
        added = 0
        for pdir in project_dirs:
            project = self._project_name(pdir)
            try:
                jsonls = list(pdir.glob("*.jsonl"))
            except OSError:
                continue
            for jpath in jsonls:
                try:
                    st = jpath.stat()
                except OSError:
                    continue
                meta = self.files.get(jpath)
                if meta is None:
                    self.files[jpath] = {"pos": 0, "project": project}
                    meta = self.files[jpath]
                if st.st_size < meta["pos"]:
                    # truncation/rotation — restart this file
                    meta["pos"] = 0
                if st.st_size > meta["pos"]:
                    added += self._read_from(jpath, meta, project)
        return added

    def _read_from(self, jpath: Path, meta: dict, project: str) -> int:
        try:
            with open(jpath, "rb") as f:
                f.seek(meta["pos"])
                data = f.read()
        except OSError:
            return 0
        # Only process complete lines; leave any tail for next refresh.
        end = data.rfind(b"\n")
        if end < 0:
            return 0
        complete = data[: end + 1]
        meta["pos"] += end + 1
        added = 0
        for raw in complete.splitlines():
            result = self._parse(raw)
            if result is None:
                continue
            ev_tuple, branch, cwd = result
            ts, sid, model, in_, out, cc, cr = ev_tuple
            self.events.append((ts, project, sid, model, in_, out, cc, cr))
            sm = self.session_meta.get(sid)
            if sm is None or ts >= sm.get("last_ts", 0):
                self.session_meta[sid] = {
                    "branch": branch,
                    "cwd": cwd,
                    "project": project,
                    "model": model,
                    "last_ts": ts,
                }
            added += 1
        return added

    def _parse(self, raw: bytes):
        """Returns ((ts, sid, model, in, out, cc, cr), branch, cwd) or None."""
        if not raw:
            return None
        try:
            d = json.loads(raw)
        except (json.JSONDecodeError, ValueError):
            self.errors += 1
            return None
        msg = d.get("message")
        if not isinstance(msg, dict):
            return None
        usage = msg.get("usage")
        if not isinstance(usage, dict):
            return None
        ts_str = d.get("timestamp")
        if not ts_str:
            return None
        try:
            ts = _iso_to_epoch(ts_str)
        except (ValueError, TypeError):
            self.errors += 1
            return None
        model = msg.get("model") or "?"
        sid = d.get("sessionId") or "?"
        ev = (
            ts, sid, model,
            int(usage.get("input_tokens", 0) or 0),
            int(usage.get("output_tokens", 0) or 0),
            int(usage.get("cache_creation_input_tokens", 0) or 0),
            int(usage.get("cache_read_input_tokens", 0) or 0),
        )
        return ev, d.get("gitBranch") or "", d.get("cwd") or ""

    # ── aggregations ────────────────────────────────────────────────

    def aggregate(self, since: float = None, until: float = None) -> dict:
        """Sum tokens within window. Returns dict with totals, by_project, by_model, by_session."""
        z = lambda: dict(in_=0, out=0, cc=0, cr=0, msgs=0)  # noqa: E731
        by_proj = defaultdict(z)
        by_model = defaultdict(z)
        by_session = {}
        totals = z()
        for ev in self.events:
            ts = ev[self.TS]
            if since is not None and ts < since:
                continue
            if until is not None and ts > until:
                continue
            proj = ev[self.PROJECT]
            sid = ev[self.SID]
            model = ev[self.MODEL]
            in_, out, cc, cr = ev[self.IN], ev[self.OUT], ev[self.CC], ev[self.CR]
            for bucket in (by_proj[proj], by_model[model], totals):
                bucket["in_"] += in_
                bucket["out"] += out
                bucket["cc"] += cc
                bucket["cr"] += cr
                bucket["msgs"] += 1
            s = by_session.get(sid)
            if s is None:
                s = dict(in_=0, out=0, cc=0, cr=0, msgs=0,
                         project=proj, model=model, first=ts, last=ts)
                by_session[sid] = s
            s["in_"] += in_
            s["out"] += out
            s["cc"] += cc
            s["cr"] += cr
            s["msgs"] += 1
            s["model"] = model  # keep last model used
            if ts > s["last"]:
                s["last"] = ts
            if ts < s["first"]:
                s["first"] = ts
        return {
            "totals": totals,
            "by_project": dict(by_proj),
            "by_model": dict(by_model),
            "by_session": by_session,
        }

    def history_daily(self, days: int = 7) -> list:
        """Returns [(date, total_tokens), …] oldest → newest, len == days."""
        today = datetime.now().date()
        buckets = {today - timedelta(days=i): 0 for i in range(days)}
        for ev in self.events:
            d = datetime.fromtimestamp(ev[self.TS]).date()
            if d in buckets:
                buckets[d] += ev[self.IN] + ev[self.OUT] + ev[self.CC] + ev[self.CR]
        return sorted(buckets.items())

    def session_events(self, sid: str) -> list:
        """All events for a session, oldest-first."""
        evs = [e for e in self.events if e[self.SID] == sid]
        evs.sort(key=lambda e: e[self.TS])
        return evs

    def recent_burn(self, now: float, lookback_seconds: int = 1800) -> float:
        """Tokens (in+out) per minute over the last lookback_seconds."""
        cutoff = now - lookback_seconds
        total = 0
        for ev in self.events:
            if ev[self.TS] >= cutoff:
                total += ev[self.IN] + ev[self.OUT]
        return total / (lookback_seconds / 60) if lookback_seconds > 0 else 0

    def hourly_peaks(self, now_ts: float, hours: int = 24) -> list:
        """For each of the last `hours` hours, return the *peak* tokens-per-minute
        (input and output, separately) observed within that hour.

        Same metric Anthropic's Console shows on the rate-limit charts. Computed
        from the same `usage` numbers Anthropic returned for each request — just
        bucketed locally.

        Returns: [{"hour_ts": epoch, "max_in": int, "max_out": int}, …]
                 oldest first, length == hours.
        """
        end_hour = int(now_ts // 3600) * 3600
        start_hour = end_hour - (hours - 1) * 3600
        # (hour_idx, minute_idx) -> [in_sum, out_sum]
        by_minute: dict = defaultdict(lambda: [0, 0])
        for ev in self.events:
            ts = ev[self.TS]
            if ts < start_hour or ts >= end_hour + 3600:
                continue
            hour_idx = int((ts - start_hour) // 3600)
            minute_idx = int(ts // 60)
            by_minute[(hour_idx, minute_idx)][0] += ev[self.IN]
            by_minute[(hour_idx, minute_idx)][1] += ev[self.OUT]
        peaks = [{"hour_ts": start_hour + h * 3600, "max_in": 0, "max_out": 0}
                 for h in range(hours)]
        for (hi, _mi), (mi_in, mi_out) in by_minute.items():
            if 0 <= hi < hours:
                if mi_in > peaks[hi]["max_in"]:
                    peaks[hi]["max_in"] = mi_in
                if mi_out > peaks[hi]["max_out"]:
                    peaks[hi]["max_out"] = mi_out
        return peaks

    def historic_max_5h(self, now: float, days: int = 30) -> tuple:
        """Sliding 5h window over last `days` days. Returns (max_in_out_tokens, end_ts).
        end_ts is the epoch second at which the busiest window ended.
        Excludes the currently-open 5h window (last 5h before `now`) so the bar
        compares now vs. *previous* peaks, not now vs. itself.
        """
        cutoff_old = now - days * 86400
        cutoff_recent = now - 5 * 3600  # exclude current rolling window
        evs = sorted(
            (e for e in self.events
             if cutoff_old <= e[self.TS] <= cutoff_recent),
            key=lambda e: e[self.TS],
        )
        if not evs:
            return (0, 0)
        window = 5 * 3600
        best = 0
        best_end = 0
        left = 0
        running = 0
        for right, ev_r in enumerate(evs):
            ts_r = ev_r[self.TS]
            running += ev_r[self.IN] + ev_r[self.OUT]
            while left < right and ts_r - evs[left][self.TS] > window:
                running -= evs[left][self.IN] + evs[left][self.OUT]
                left += 1
            if running > best:
                best = running
                best_end = ts_r
        return (best, best_end)


def total_tokens(bucket: dict) -> int:
    return bucket["in_"] + bucket["out"] + bucket["cc"] + bucket["cr"]


def window_bounds(mode: str, now: float) -> tuple:
    """Returns (since, until, label) for a window mode."""
    for name, span in WINDOW_MODES:
        if name == mode:
            if span == "today":
                start = datetime.fromtimestamp(now).replace(
                    hour=0, minute=0, second=0, microsecond=0
                ).timestamp()
                return start, now, "today"
            return now - span, now, name
    return now - 5 * 3600, now, "5h"


