def draw_agent_detail_pane(stdscr, x0, y0, w, h, job):
    """Master-Detail right pane: the FULL state of the selected fleet agent —
    health, schedule, cause, fix, log tail — so pruefen-dann-verbessern is one
    glance plus one Enter (which opens Claude Code seeded on this agent)."""
    clamp = x0 + w
    health = job.get("health") or agent_health(job)
    state = health["state"]
    short = job["label"].replace("com.hausverwaltung.", "")
    cpair = curses.color_pair(HEALTH_COLOR.get(state, 4))

    safe_addstr(stdscr, y0, x0, f" {short}", curses.A_BOLD, clamp)
    safe_addstr(stdscr, y0 + 1, x0, " " + "─" * (w - 2), curses.A_DIM, clamp)

    def field(row, label, value, attr=0):
        safe_addstr(stdscr, row, x0, f" {label:<9}", curses.A_DIM, clamp)
        safe_addstr(stdscr, row, x0 + 10, value[: w - 11], attr, clamp)

    y = y0 + 2
    field(y, "State", f"{HEALTH_ICON[state]} {HEALTH_LABEL_DE[state]}", cpair | curses.A_BOLD); y += 1
    field(y, "Schedule", job["schedule"]); y += 1
    field(y, "PID/Exit", f"{job['pid']} / {job['exit']}   log {human_size(job['log_size'])}"); y += 1
    log_p = job.get("log_path") or "—"
    field(y, "Log", log_p.replace(str(Path.home()), "~")); y += 1

    def wrapped(row, label, text, attr=0, max_lines=3):
        lines = textwrap.wrap(text, max(10, w - 12)) or ["—"]
        for i, ln in enumerate(lines[:max_lines]):
            safe_addstr(stdscr, row + i, x0, f" {label if i == 0 else '':<9}", curses.A_DIM, clamp)
            safe_addstr(stdscr, row + i, x0 + 10, ln, attr, clamp)
        return row + min(len(lines), max_lines)

    y += 1
    y = wrapped(y, "Ursache", health["symptom"], cpair)
    if health["fix"]:
        y = wrapped(y, "Fix", health["fix"], curses.color_pair(3))
    desc = agent_description(job)
    if desc:
        y = wrapped(y, "Zweck", desc, curses.A_DIM, max_lines=2)

    # log tail fills the rest, minus the action bar
    tail_top = y + 1
    tail_h = (y0 + h) - tail_top - 1
    if tail_h > 1:
        safe_addstr(stdscr, tail_top, x0, " ─ log tail " + "─" * max(0, w - 13), curses.A_DIM, clamp)
        lines = _log_tail(job.get("log_path"), tail_h - 1)
        for i, ln in enumerate(lines[-(tail_h - 1):]):
            attr = curses.color_pair(2) if re.search(r"ERROR|FAIL", ln) else curses.A_DIM
            safe_addstr(stdscr, tail_top + 1 + i, x0, " " + ln[: w - 2], attr, clamp)
    if is_fleet_agent(job["label"]):
        bar = " ↵ Fix mit Claude   x an/aus   R restart   l Log"
        safe_addstr(stdscr, y0 + h - 1, x0, bar[: w - 1], curses.A_BOLD, clamp)


def _claude_badge(index, limits, now) -> str:
    """One-line spend summary for the header while the right pane shows agent
    detail (v2 made these queries ~2ms, so per-frame is fine)."""
    five_h = index.aggregate(since=now - 5 * 3600)["totals"]
    burn = index.recent_burn(now)
    badge = f"⚡ 5h {_fmt_tokens(total_tokens(five_h))}"
    if burn >= 1:
        badge += f" · {_fmt_tokens(int(burn))}/min"
    return badge


def draw(stdscr, jobs, sel_l, scroll_l, filter_str,
         index, limits, sel_c, window_mode, focus, status_msg="",
         fleet_only=False):
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    user = getpass.getuser()

    # Top header
    title = "agenttop"
    info = f"  {user} · {'deine Flotte' if fleet_only else 'alle launchd-Jobs'}   "
    keys = (_claude_badge(index, limits, time.time()) if fleet_only
            else "Tab focus  q quit  r refresh  f fetch")
    safe_addstr(stdscr, 0, 0, title, curses.A_BOLD, w)
    safe_addstr(stdscr, 0, len(title), info, curses.A_DIM, w)
    if w > len(title) + len(info) + len(keys) + 3:
        safe_addstr(stdscr, 0, w - len(keys) - 1, keys,
                    curses.A_BOLD if fleet_only else curses.A_DIM, w)

    launchd_w, claude_w = _split_widths(w)
    body_top = 1
    body_h = h - body_top - 1  # leave 1 for footer

    sessions_list = []
    if claude_w == 0:
        if focus == "launchd":
            scroll_l, sel_l, _filtered = draw_launchd_pane(
                stdscr, 0, body_top, w, body_h, jobs, sel_l, scroll_l,
                filter_str, focused=True,
            )
        else:
            sel_c, sessions_list = draw_claude_pane(
                stdscr, 0, body_top, w, body_h, index, limits,
                window_mode, sel_c, focused=True,
            )
    else:
        scroll_l, sel_l, _filtered = draw_launchd_pane(
            stdscr, 0, body_top, launchd_w, body_h, jobs, sel_l, scroll_l,
            filter_str, focused=(focus == "launchd"),
        )
        for y in range(body_top, body_top + body_h):
            safe_addstr(stdscr, y, launchd_w, "│", curses.A_DIM, w)
        if fleet_only and _filtered and focus == "launchd":
            sel_safe = min(sel_l, len(_filtered) - 1)
            draw_agent_detail_pane(
                stdscr, launchd_w + 1, body_top, claude_w, body_h,
                _filtered[sel_safe],
            )
        else:
            sel_c, sessions_list = draw_claude_pane(
                stdscr, launchd_w + 1, body_top, claude_w, body_h, index,
                limits, window_mode, sel_c, focused=(focus == "claude"),
            )

    # Footer
    footer_y = h - 1
    if status_msg:
        attr = curses.color_pair(2) | curses.A_BOLD if "fail" in status_msg.lower() \
               else curses.color_pair(1) | curses.A_BOLD
        safe_addstr(stdscr, footer_y, 0, status_msg, attr, w)
    elif filter_str and focus == "launchd":
        safe_addstr(stdscr, footer_y, 0,
                    f"filter: /{filter_str}    (c to clear)", curses.A_DIM, w)
    else:
        if fleet_only:
            hint = ("[tokens]  v window  Enter session tail  Tab zurück zum Detail"
                    if focus == "claude"
                    else "j/k  ↵ Fix mit Claude  Tab Tokens  x an/aus  l Log  R restart  a alle  / filter  q")
        else:
            hint = ("[launchd] / filter  R restart  s stop  l/Enter tail  a Flotte"
                    if focus == "launchd"
                    else "[claude]  v window  f fetch limits  Enter session tail")
        safe_addstr(stdscr, footer_y, 0, hint, curses.A_DIM, w)

    stdscr.refresh()
    return scroll_l, sel_l, sel_c, sessions_list


def main(stdscr):
    curses.curs_set(0)
    curses.start_color()
    curses.use_default_colors()
    # DESIGN.md — B2 „Papier" (Notion im Terminal): Farbe existiert nur, wo etwas
    # dich braucht. Gesund ist STUMM — bewusst kein Grün: das Farbbudget gehört
    # der Abweichung, der eine rote Punkt im ruhigen Bild ist die Botschaft.
    # bg bleibt Terminal-Default (heller Primär / dunkler Zwilling kommen vom
    # Terminal-Theme); die 256c-Indexe sind auf beiden lesbar gewählt.
    # Dan-Override 2026-07-15: healthy ist GRÜN (weiches 65, k9s-Stil), denn
    # grau bedeutet ab jetzt INAKTIV — Agenten sind per 'x' an-/abschaltbar,
    # und ein grauer gesunder Agent sah aus wie ein abgeschalteter.
    if curses.COLORS >= 256:
        curses.init_pair(1, 65, -1)    # ok/healthy — weiches Grün
        curses.init_pair(2, 131, -1)   # fail — weiches Rot, nie #FF0000
        curses.init_pair(3, 136, -1)   # warn — Bernstein
        curses.init_pair(4, -1, -1)    # ink — Terminal-Default
        curses.init_pair(5, 245, -1)   # dim — INAKTIV/disabled + transient
    else:
        curses.init_pair(1, curses.COLOR_GREEN, -1)
        curses.init_pair(2, curses.COLOR_RED, -1)
        curses.init_pair(3, curses.COLOR_YELLOW, -1)
        curses.init_pair(4, -1, -1)
        curses.init_pair(5, -1, -1)

    stdscr.timeout(2000)

    # Initial scan can take a moment on big indexes — show a splash.
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    safe_addstr(stdscr, h // 2, max(0, (w - 28) // 2),
                "scanning ~/.claude/projects…", curses.A_DIM)
    stdscr.refresh()

    index = ClaudeIndex()
    index.refresh()
    index.save()  # warm/refresh the on-disk cache (prunes internally)
    last_save = time.time()
    limits = LimitsFetcher()
    if limits.is_stale():
        limits.fetch_async()  # background; UI shows cached value or "fetching…"

    fleet_only = True   # default lens: only YOUR agents (com.hausverwaltung.*), never vendor jobs — 'a' toggles

    def visible_jobs():
        js = collect_jobs()
        if not fleet_only:
            return js
        js = [j for j in js if is_fleet_agent(j["label"])]
        for j in js:
            h_ = agent_health(j)
            j["health"] = h_
            j["icon"] = HEALTH_ICON[h_["state"]]
            j["color"] = HEALTH_COLOR[h_["state"]]
            j["status_text"] = h_["state"]
            # list shows the bare agent name; the prefix is noise here
            d = j["label"]
            for pfx in FLEET_PREFIXES:
                if d.startswith(pfx):
                    d = d[len(pfx):]
                    break
            j["display"] = d
        # worst first — the thing that needs you is always at the top
        js.sort(key=lambda j: (HEALTH_ORDER.index(j["health"]["state"]), j["label"]))
        return js

    prev_states: dict = {}

    def notify_worsened(js):
        """While agenttop is open, a fleet agent flipping to failing/blocked/dead
        fires a click-to-investigate notification — same anti-'unnoticed' guard
        the Observer applies between its Wednesday runs."""
        bad = ("failing", "blocked", "dead")
        for j in js:
            state = (j.get("health") or {}).get("state")
            prev = prev_states.get(j["label"])
            prev_states[j["label"]] = state
            if state in bad and prev is not None and prev not in bad:
                if shutil.which("terminal-notifier"):
                    short = j["label"].replace("com.hausverwaltung.", "")
                    subprocess.Popen([
                        "terminal-notifier",
                        "-title", f"agenttop: {short} → {state.upper()}",
                        "-message", (j["health"].get("fix") or "")[:120],
                        "-execute", str(Path.home() / ".local" / "bin" / "hausverwaltung-observer-investigate.sh") + " " + j["label"],
                        "-group", "agenttop-health",
                    ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    jobs = visible_jobs()
    sel_l = 0
    scroll_l = 0
    sel_c = 0
    filter_str = ""
    window_mode = "5h"
    focus = "launchd"
    status_msg = ""
    status_msg_until = 0
    tick = 0

    def current_view():
        return [j for j in jobs if filter_str.lower() in j["label"].lower()] if filter_str else jobs

    while True:
        scroll_l, sel_l, sel_c, sessions_list = draw(
            stdscr, jobs, sel_l, scroll_l, filter_str,
            index, limits, sel_c, window_mode, focus, status_msg,
            fleet_only=fleet_only,
        )
        ch = stdscr.getch()
        tick += 1
        if status_msg and tick > status_msg_until:
            status_msg = ""
        if ch == -1:
            jobs = visible_jobs()
            if fleet_only:
                notify_worsened(jobs)
            added = index.refresh()
            if limits.is_stale():
                limits.fetch_async()
            if added and time.time() - last_save > SAVE_INTERVAL_SECONDS:
                index.save()
                last_save = time.time()
            continue

        # Global keys
        if ch == curses.KEY_RESIZE:
            # Terminal resized (or a pane split/unsplit): drop the stale frame and
            # let draw() recompute widths from a fresh getmaxyx on the next tick.
            stdscr.clear()
            continue
        if ch == ord('a'):
            fleet_only = not fleet_only
            jobs = visible_jobs()
            sel_l = 0
            scroll_l = 0
            status_msg = "Alle launchd-Agenten" if not fleet_only else "Nur deine Flotte (com.hausverwaltung.*)"
            status_msg_until = tick + 3
            continue
        if ch in (ord('q'), ord('Q')):
            index.save()
            break
        if ch == 9:  # Tab
            # Fleet mode: Tab flips the RIGHT pane between agent detail and the
            # full Claude/token view — one key straight to the token usage.
            focus = "claude" if focus == "launchd" else "launchd"
            continue
        if ch == ord('r'):
            jobs = visible_jobs()
            index.refresh()
            status_msg = "Refreshed"
            status_msg_until = tick + 2
            continue
        if ch == ord('f'):
            limits.fetch_async()
            status_msg = "Fetching Anthropic limits…"
            status_msg_until = tick + 4
            continue

        # Pane-specific keys
        if focus == "launchd":
            if ch == ord('/'):
                new = edit_filter(stdscr, filter_str)
                if new is not None:
                    filter_str = new
                    sel_l = 0
                    scroll_l = 0
            elif ch == ord('c'):
                filter_str = ""
                sel_l = 0
                scroll_l = 0
            elif ch in (curses.KEY_DOWN, ord('j')):
                sel_l += 1
            elif ch in (curses.KEY_UP, ord('k')):
                sel_l = max(0, sel_l - 1)
            elif ch == ord('g'):
                sel_l = 0
                scroll_l = 0
            elif ch == ord('G'):
                sel_l = len(jobs) - 1
            elif ch == ord('R'):
                view = current_view()
                if 0 <= sel_l < len(view):
                    status_msg = restart_job(view[sel_l])
                    status_msg_until = tick + 4
                    jobs = visible_jobs()
            elif ch == ord('s'):
                view = current_view()
                if 0 <= sel_l < len(view):
                    status_msg = stop_job(view[sel_l])
                    status_msg_until = tick + 4
                    jobs = visible_jobs()
            elif ch == ord('x'):
                view = current_view()
                if 0 <= sel_l < len(view) and is_fleet_agent(view[sel_l]["label"]):
                    status_msg = toggle_agent(view[sel_l])
                    status_msg_until = tick + 4
                    jobs = visible_jobs()
            elif ch == ord('l'):
                view = current_view()
                if 0 <= sel_l < len(view):
                    tail_log(stdscr, view[sel_l])
            elif ch in (10, 13):
                view = current_view()
                if 0 <= sel_l < len(view):
                    job = view[sel_l]
                    if is_fleet_agent(job["label"]):
                        # the hub move: open Claude Code on THIS agent, seeded to fix it
                        status_msg = launch_claude_on_agent(job)
                        status_msg_until = tick + 4
                    else:
                        tail_log(stdscr, job)  # vendor job — no Claude prompt, just its log
        else:  # focus == "claude"
            if ch in (curses.KEY_DOWN, ord('j')):
                sel_c += 1
            elif ch in (curses.KEY_UP, ord('k')):
                sel_c = max(0, sel_c - 1)
            elif ch == ord('v'):
                modes = [m for m, _ in WINDOW_MODES]
                window_mode = modes[(modes.index(window_mode) + 1) % len(modes)]
            elif ch in (10, 13):
                if 0 <= sel_c < len(sessions_list):
                    sid, info = sessions_list[sel_c]
                    tail_claude_session(stdscr, index, sid, info["project"])


# ── entrypoint ──────────────────────────────────────────────────────


def _once_launchd():
    for j in collect_jobs():
        print(f"{j['icon']} {j['label']:<50} {j['schedule']:<22} pid={j['pid']:<6} {j['status_text']:<14} log={human_size(j['log_size'])}")


def _once_claude():
    idx = ClaudeIndex()
    idx.refresh()
    idx.save()  # warm/refresh the shared on-disk cache
    now = datetime.now().timestamp()
    agg = idx.aggregate(since=now - 5 * 3600, until=now)
    t = agg["totals"]
    print("=== Anthropic real rate-limit headers ===")
    fetch_arg = "--no-fetch" not in sys.argv
    if fetch_arg:
        print("(making one tiny `claude -p .` call to read headers — costs 1 message)")
        ld = fetch_anthropic_limits()
        if ld and "error" not in ld:
            try:
                LIMITS_CACHE.parent.mkdir(parents=True, exist_ok=True)
                LIMITS_CACHE.write_text(json.dumps(ld))
            except OSError:
                pass
    else:
        try:
            ld = json.loads(LIMITS_CACHE.read_text())
            age = int(time.time() - ld.get("ts", 0))
            print(f"(using cached headers, {age}s old; pass --fetch to refresh)")
        except (OSError, json.JSONDecodeError):
            ld = {}
    if "error" in ld:
        print(f"  error: {ld['error']}")
    elif ld:
        for k in ("5h", "7d"):
            u = ld.get(f"{k}_util")
            r = ld.get(f"{k}_reset")
            s = ld.get(f"{k}_status")
            if u is not None:
                reset_str = (datetime.fromtimestamp(r).strftime("%a %d %H:%M")
                             if r else "?")
                print(f"  {k}: {u * 100:5.1f}% used  status={s}  resets at {reset_str}")
        print(f"  overall status: {ld.get('status')}  "
              f"representative claim: {ld.get('representative')}")
    print()
    print(f"=== Local activity (last 5h, from ~/.claude/projects/*.jsonl) ===")
    print(f"sessions: {len(agg['by_session'])}   messages: {t['msgs']}")
    print(f"in {_fmt_tokens(t['in_'])}  out {_fmt_tokens(t['out'])}  "
          f"cc {_fmt_tokens(t['cc'])}  cr {_fmt_tokens(t['cr'])}  "
          f"Σ {_fmt_tokens(total_tokens(t))}")
    print()
    print("By model:")
    for m, b in sorted(agg["by_model"].items(), key=lambda kv: -total_tokens(kv[1])):
        print(f"  {_short_model(m):<16} Σ {_fmt_tokens(total_tokens(b)):>8}  msgs {b['msgs']}")
    print()
    print("Active sessions (branch / model / last / tokens):")
    sess_sorted = sorted(agg["by_session"].items(), key=lambda kv: -kv[1]["last"])
    for sid, b in sess_sorted[:10]:
        sm = idx.session_meta.get(sid, {})
        branch = sm.get("branch") or os.path.basename(sm.get("cwd") or "") or b["project"]
        print(f"  {_short_branch(branch, 32):<32} {_short_model(b['model']):<14} "
              f"{_fmt_relative(b['last'], now):<10} Σ {_fmt_tokens(total_tokens(b)):>8}  {sid[:6]}")
    print()
    print("Last 24h — peak tokens/min per hour:")
    peaks = idx.hourly_peaks(now, hours=24)
    in_vals = [p["max_in"] for p in peaks]
    out_vals = [p["max_out"] for p in peaks]
    in_max = max(in_vals) if in_vals else 0
    out_max = max(out_vals) if out_vals else 0
    print(f"  in   {_sparkline(in_vals, in_max)}    peak {_fmt_tokens(in_max)}")
    print(f"  out  {_sparkline(out_vals, out_max)}    peak {_fmt_tokens(out_max)}")
    if peaks:
        t0 = datetime.fromtimestamp(peaks[0]["hour_ts"]).strftime("%H:%M")
        tn = datetime.fromtimestamp(peaks[-1]["hour_ts"]).strftime("%H:%M")
        print(f"       {t0}{' ' * 18}{tn}")


if __name__ == "__main__":
    if "--once" in sys.argv:
        _once_launchd()
        sys.exit(0)
    if "--once-claude" in sys.argv:
        _once_claude()
        sys.exit(0)
    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        pass
