# One-sentence purpose per agent for the detail pane — names alone don't say
# what a job DOES. Two sources: a local overrides file (curated one-liners,
# stays out of this public repo) and, as the self-maintaining fallback, the
# first comment line of the agent's own script (the wrappers all carry a
# "# <name> — what it does." header).
DESC_OVERRIDES_PATH = Path.home() / ".config" / "agenttop" / "descriptions.json"
_DESC_CACHE: dict = {"overrides": None, "by_label": {}}


def agent_description(job: dict) -> str:
    if _DESC_CACHE["overrides"] is None:
        try:
            _DESC_CACHE["overrides"] = json.loads(DESC_OVERRIDES_PATH.read_text())
        except (OSError, ValueError):
            _DESC_CACHE["overrides"] = {}
    label = job["label"]
    override = _DESC_CACHE["overrides"].get(label)
    if override:
        return override
    if label in _DESC_CACHE["by_label"]:
        return _DESC_CACHE["by_label"][label]
    desc = ""
    for arg in (job.get("program") or "").split():
        # only real script files — /bin/zsh, flags and binaries have no header
        if not (os.path.isfile(arg) and not arg.startswith(("/bin/", "/usr/bin/", "/opt/"))):
            continue
        try:
            with open(arg, errors="ignore") as f:
                head = f.read(4000).splitlines()[:12]
        except OSError:
            continue
        for ln in head:
            ln = ln.strip()
            if ln.startswith("#") and not ln.startswith("#!") and "-*-" not in ln:
                desc = ln.lstrip("#").strip()
                break
        if desc:
            break
    _DESC_CACHE["by_label"][label] = desc
    return desc


# launchctl print-disabled is one subprocess for the WHOLE domain — cache it a
# few ticks instead of paying it once per agent per 2s refresh.
_DISABLED_CACHE = {"ts": 0.0, "labels": frozenset()}


def disabled_labels() -> frozenset:
    now = time.time()
    if now - _DISABLED_CACHE["ts"] < 5:
        return _DISABLED_CACHE["labels"]
    try:
        out = subprocess.run(["launchctl", "print-disabled", f"gui/{os.getuid()}"],
                             capture_output=True, text=True, timeout=5).stdout
        labels = frozenset(re.findall(r'"([^"]+)"\s*=>\s*(?:true|disabled)', out))
    except (subprocess.SubprocessError, OSError):
        labels = _DISABLED_CACHE["labels"]
    _DISABLED_CACHE.update(ts=now, labels=labels)
    return labels


def toggle_agent(job: dict) -> str:
    """'x': flip an agent between active and deliberately-off. Disable is
    PERSISTENT (survives reboots) + bootout unloads it now; enable + bootstrap
    brings it back immediately. Both directions are fully reversible."""
    label = job["label"]
    target = f"gui/{os.getuid()}"
    if label in disabled_labels():
        subprocess.run(["launchctl", "enable", f"{target}/{label}"], capture_output=True, timeout=10)
        r = subprocess.run(["launchctl", "bootstrap", target, job.get("plist_path", "")],
                           capture_output=True, text=True, timeout=10)
        _DISABLED_CACHE["ts"] = 0.0  # force re-read on next tick
        return (f"{label.split('.')[-1]} AN (enable + bootstrap)" if r.returncode == 0
                else f"enable ok, bootstrap: {(r.stderr or r.stdout).strip().splitlines()[-1] if (r.stderr or r.stdout) else 'Fehler'}")
    subprocess.run(["launchctl", "bootout", f"{target}/{label}"], capture_output=True, timeout=10)
    r = subprocess.run(["launchctl", "disable", f"{target}/{label}"], capture_output=True, text=True, timeout=10)
    _DISABLED_CACHE["ts"] = 0.0
    return (f"{label.split('.')[-1]} AUS (bootout + disable — 'x' schaltet wieder an)"
            if r.returncode == 0 else "disable fehlgeschlagen")


def is_fleet_agent(label: str) -> bool:
    return any(label.startswith(p) for p in FLEET_PREFIXES)


def _blocking_skip(text: str) -> bool:
    return bool(re.search(r"uncommitted|dirty|not a git|no such|command not found|missing|permission denied|cannot", text, re.I))


def fix_hint(symptom: str) -> str:
    s = symptom.lower()
    if "claude exited" in s or "infra failure" in s or ("error" in s and "claude" in s):
        return "Anthropic-Guthaben/Key + Gateway prüfen; Agent manuell laufen lassen für die verschluckte Fehlermeldung"
    if "uncommitted" in s or "dirty" in s:
        return "Haupt-Checkout aufräumen: untrackte/geänderte Dateien committen oder ignorieren"
    if "not loaded" in s:
        return "launchctl bootstrap gui/$(id -u) <plist>"
    if "no run in" in s or "no run" in s:
        return "plist-Zeitplan prüfen; lief der Mac zur geplanten Zeit? (verpasste Jobs laufen erst beim Aufwachen)"
    if "unreachable" in s or "network" in s:
        return "transient (kein Netz zur Cron-Zeit) — klärt sich beim nächsten Lauf"
    if "command not found" in s or "missing" in s:
        return "fehlendes Binary im PATH des Wrappers — installieren oder PATH-Zeile ergänzen"
    return "Log-Tail lesen und den letzten fehlgeschlagenen Schritt diagnostizieren"


def _log_tail(path: str, n: int = 60) -> list:
    if not path:
        return []
    try:
        with open(path, "r", errors="ignore") as f:
            return f.read().splitlines()[-n:]
    except OSError:
        return []


def agent_health(job: dict) -> dict:
    """Classify one fleet agent: {state, symptom, fix}. A silent skip exits 0, so
    trust the log tail's most-recent outcome over LastExitStatus."""
    # Deliberately switched off ('x') — grey by design, and no other check
    # applies: an off agent has no pid, no fresh log, and that is CORRECT.
    if job["label"] in disabled_labels():
        return {"state": "disabled", "symptom": "bewusst abgeschaltet ('x' schaltet wieder an)", "fix": ""}
    # A keep-alive service that is running RIGHT NOW is healthy no matter how old
    # its log is (bridge/tunnel write nothing for days when traffic is quiet).
    if job["pid"] not in ("-", "", None):
        return {"state": "healthy", "symptom": f"läuft (pid {job['pid']})", "fix": ""}
    if job["pid"] == "-" and job["exit"] == "-" and not job.get("log_path"):
        return {"state": "unknown", "symptom": "no launchctl/log signal", "fix": fix_hint("")}
    # Not running and the log hasn't moved in ages → the job isn't firing at all,
    # no matter what its last outcome line says. (Caught live: a discovery cron
    # whose EMPTY log made it look healthy while it hadn't run in 41 days.)
    try:
        idle_d = (time.time() - os.path.getmtime(job["log_path"])) / 86400
        if idle_d > 14:
            sym = f"no run in {idle_d:.0f}d (log untouched)"
            return {"state": "stale", "symptom": sym, "fix": fix_hint(sym)}
    except (OSError, TypeError, ValueError):
        pass
    tail = _log_tail(job.get("log_path"))
    outcome = ""
    for line in reversed(tail):
        if re.search(r"Skipped:|Run complete|Digest complete|complete:|ERROR|FAIL|advanced|exit=|Observer complete", line, re.I):
            outcome = line.strip()
            break
    if re.search(r"ERROR|FAIL|exit=[1-9]", outcome):
        return {"state": "failing", "symptom": outcome, "fix": fix_hint(outcome)}
    if re.search(r"Skipped:", outcome, re.I):
        reason = outcome.split("Skipped:", 1)[-1].strip()
        if _blocking_skip(reason):
            # dirty-tree skip: the log is stale — is the named repo clean NOW?
            m = re.search(r"(/[^ ]+) has uncommitted", reason)
            if m and os.path.isdir(os.path.join(m.group(1), ".git")):
                clean = subprocess.run(["git", "-C", m.group(1), "status", "--porcelain"],
                                       capture_output=True, text=True).stdout.strip() == ""
                if clean:
                    return {"state": "recovering", "symptom": "letzter Lauf blockiert (dirty tree), Baum jetzt sauber", "fix": "nichts — klärt sich beim nächsten Lauf"}
            return {"state": "blocked", "symptom": reason, "fix": fix_hint(reason)}
        return {"state": "transient", "symptom": reason, "fix": fix_hint(reason)}
    if outcome:
        return {"state": "healthy", "symptom": outcome, "fix": ""}
    return {"state": "healthy", "symptom": "läuft", "fix": ""}


def launch_claude_on_agent(job: dict) -> str:
    """Open a focused herdr workspace with a FRESH Claude Code session, seeded
    with everything it needs (plist, program, symptom, fix approach AND the last
    log lines inline) so it can go straight to solving — no warm-up tool calls.

    Hard lessons baked in (2026-07-15, live failure): the session name must be
    UNIQUE (a fixed name collides with any other running claude → agent_name_taken
    and an empty workspace), herdr's output must be CAPTURED (Popen inheriting
    stdout bleeds error-JSON over the curses screen), and a failed start must be
    said out loud + cleaned up — never report 'öffnet …' for a spawn that died.
    """
    label = job["label"]
    short = label.split(".")[-1]
    log = job.get("log_path") or ""
    program = job.get("program") or "?"
    health = agent_health(job)
    tail_lines = _log_tail(log, 30)
    tail_txt = "\n".join(ln[:300] for ln in tail_lines)[-4000:] or "<Log leer>"
    prompt = (
        f"Du arbeitest an dem launchd-Agenten `{label}`. agenttop hat ihn als '{health['state']}' markiert.\n\n"
        f"- Programm: {program}\n- plist: {job.get('plist_path', '?')}\n- Log: {log}\n"
        f"- Symptom: {health['symptom']}\n- Fix-Ansatz: {health['fix']}\n\n"
        f"Die letzten Log-Zeilen (frisch beim Öffnen dieser Session):\n```\n{tail_txt}\n```\n\n"
        "Aufgabe: ECHTE Ursache finden — Programm-Skript lesen, bei Bedarf mehr Log; bei 'claude exited 1' den Agenten EINMAL manuell mit sichtbarem Output laufen lassen. "
        "Den Fix anwenden WENN eindeutig sicher, sonst vorschlagen. Am Ende 3 Sätze: Ursache, Fix (getan/vorgeschlagen), läuft der nächste geplante Lauf durch. "
        "Fass keine anderen Agenten an."
    )

    def fallback(reason: str) -> str:
        if log:
            subprocess.run(["open", log], capture_output=True)
            return f"{reason} — Log geöffnet"
        return reason

    if not shutil.which("herdr"):
        return fallback("herdr fehlt")

    def herdr_error(out: str) -> str:
        try:
            return json.loads(out).get("error", {}).get("code", "")
        except (ValueError, AttributeError):
            return ""

    # cwd: the agent's own WorkingDirectory wins; hausverwaltung agents get the
    # repo (CLAUDE.md-Kontext); everything else starts at home.
    workdir = job.get("workdir") or (
        str(Path.home() / "hausverwaltung") if label.startswith("com.hausverwaltung.")
        else str(Path.home()))
    # Unique per press — every Enter is a FRESH session by design.
    name = f"fix-{short}-{time.strftime('%H%M%S')}"

    # Inside herdr, agenttop knows its own tab (HERDR_TAB_ID is set in every
    # pane): split RIGHT next to this very session — agenttop stays visible on
    # the left, Claude works beside it. Anchor to OUR tab explicitly; splitting
    # relative to the focused pane would land in whatever tab the user switched
    # to. Outside herdr, fall back to a fresh dedicated workspace.
    own_tab = os.environ.get("HERDR_TAB_ID", "")
    wsid = ""
    try:
        if own_tab:
            start = subprocess.run(["herdr", "agent", "start", name, "--tab", own_tab,
                                    "--split", "right", "--focus", "--cwd", workdir,
                                    "--", "claude", prompt],
                                   capture_output=True, text=True, timeout=20)
            err = herdr_error(start.stdout)
            if start.returncode != 0 or err:
                return fallback(f"herdr split: {err or 'exit ' + str(start.returncode)}")
            return f"Claude ({name}) öffnet rechts daneben …"

        ws = subprocess.run(["herdr", "workspace", "create", "--cwd", workdir,
                             "--label", f"🔭 {short}", "--focus"],
                            capture_output=True, text=True, timeout=15)
        err = herdr_error(ws.stdout)
        if ws.returncode != 0 or err:
            return fallback(f"herdr workspace: {err or 'exit ' + str(ws.returncode)}")
        wsid = json.loads(ws.stdout)["result"]["workspace"]["workspace_id"]
        start = subprocess.run(["herdr", "agent", "start", name, "--workspace", wsid,
                                "--focus", "--", "claude", prompt],
                               capture_output=True, text=True, timeout=20)
        err = herdr_error(start.stdout)
        if start.returncode != 0 or err:
            # never leave an empty shell behind
            subprocess.run(["herdr", "workspace", "close", wsid], capture_output=True, timeout=10)
            return fallback(f"herdr start: {err or 'exit ' + str(start.returncode)}")
        return f"Claude ({name}) öffnet für {short} …"
    except (subprocess.SubprocessError, KeyError, ValueError, json.JSONDecodeError) as e:
        if wsid:
            subprocess.run(["herdr", "workspace", "close", wsid], capture_output=True, timeout=10)
        return fallback(f"herdr-Start fehlgeschlagen ({type(e).__name__})")


# ── Claude data layer ───────────────────────────────────────────────


def _iso_to_epoch(s: str) -> float:
    """Parse ISO-8601 to UNIX epoch. Accepts trailing Z or +00:00."""
    if s.endswith("Z"):
        s = s[:-1] + "+00:00"
    return datetime.fromisoformat(s).timestamp()


def _short_model(model: str) -> str:
    """claude-opus-4-7 → opus-4.7, claude-sonnet-4-6 → sonnet-4.6."""
    if not model:
        return "?"
    m = model
    if m.startswith("claude-"):
        m = m[len("claude-"):]
    # claude-haiku-4-5-20251001 → haiku-4-5 (drop date suffix)
    parts = m.split("-")
    keep = []
    for p in parts:
        # Drop date-shaped tokens (8 digits)
        if p.isdigit() and len(p) == 8:
            break
        keep.append(p)
    out = "-".join(keep)
    # opus-4-7 → opus-4.7 (more compact + readable)
    if len(keep) >= 3 and keep[-1].isdigit() and keep[-2].isdigit():
        out = "-".join(keep[:-2]) + "-" + keep[-2] + "." + keep[-1]
    return out


def _project_name_from_dir(d: Path) -> str:
    """Best-effort: read a cwd from any event in this dir; else last segment of dir name."""
    try:
        for jsonl in sorted(d.glob("*.jsonl")):
            try:
                with open(jsonl, "rb") as f:
                    for raw in f:
                        try:
                            ev = json.loads(raw)
                        except (json.JSONDecodeError, ValueError):
                            continue
                        cwd = ev.get("cwd")
                        if cwd:
                            base = os.path.basename(cwd)
                            if base:
                                return base
                    break  # only inspect first file
            except OSError:
                continue
    except OSError:
        pass
    name = d.name.lstrip("-")
    parts = name.split("-")
    return parts[-1] if parts else name or "?"


def _fmt_tokens(n: int) -> str:
    if n is None:
        return "-"
    if n < 1000:
        return str(n)
    if n < 1_000_000:
        return f"{n / 1000:.1f}K".replace(".0K", "K")
    if n < 1_000_000_000:
        return f"{n / 1_000_000:.1f}M".replace(".0M", "M")
    return f"{n / 1_000_000_000:.1f}G"


def _fmt_relative(ts: float, now: float) -> str:
    delta = max(0, int(now - ts))
    if delta < 60:
        return f"{delta}s ago"
    if delta < 3600:
        return f"{delta // 60}m ago"
    if delta < 86400:
        return f"{delta // 3600}h ago"
    return f"{delta // 86400}d ago"


def _fmt_duration(minutes: float) -> str:
    if minutes <= 0:
        return "now"
    if minutes >= 1440:
        return f"{int(minutes / 1440)}d"
    if minutes >= 60:
        h, m = divmod(int(minutes), 60)
        return f"{h}h {m}m" if m else f"{h}h"
    return f"{int(minutes)}m"


def _short_branch(b: str, max_len: int = 22) -> str:
    if not b:
        return ""
    if len(b) <= max_len:
        return b
    return b[: max_len - 1] + "…"


def _sparkline(values, max_val=None) -> str:
    """One-row sparkline using Unicode block heights (▁▂▃▄▅▆▇█)."""
    if not values:
        return ""
    blocks = " ▁▂▃▄▅▆▇█"
    m = max_val if max_val is not None else max(values)
    if not m:
        return blocks[0] * len(values)
    chars = []
    for v in values:
        idx = max(0, min(len(blocks) - 1, int((v / m) * (len(blocks) - 1))))
        chars.append(blocks[idx])
    return "".join(chars)


def _bar(frac: float, width: int) -> str:
    """Unicode block bar — full + partial blocks."""
    if width <= 0:
        return ""
    frac = max(0.0, min(1.0, frac))
    blocks = " ▏▎▍▌▋▊▉█"
    units = frac * width
    full = int(units)
    rem = units - full
    partial = blocks[int(rem * (len(blocks) - 1))]
    s = "█" * full + (partial if full < width else "")
    return s.ljust(width, "·")


class ClaudeIndex:
    """Incremental scan of ~/.claude/projects/**/*.jsonl — aggregated at ingest.

    On refresh(): re-stats every file, only reads newly-appended bytes. Parsed
    usage is bucketed immediately (v2): minute-grain for the last
    MINUTE_TAIL_HOURS, folded to day/hour grain beyond. No raw events are kept —
    no view ever displays one, and the raw list is what grew to 17M tuples /
    1.4GB and made both cold start and every 2s refresh slow.
    """

    # Event tuple positions (session_events still emits this shape for the
    # live-tail renderer — one tuple per MINUTE bucket there, not per event).
    TS, PROJECT, SID, MODEL, IN, OUT, CC, CR = range(8)

    def __init__(self, root: Path = None):
        self.root = root or CLAUDE_DIR
        self.files: dict = {}         # path -> {pos, project}
        # minute-grain tail: (minute_ts, sid, model) -> [in, out, cc, cr, msgs]
        self.minutes: dict = {}
        # folded history: (day_iso, project, model) -> [in, out, cc, cr, msgs]
        self.daily: dict = {}
        # folded per-session history: (day_iso, sid) -> [in, out, cc, cr, msgs]
        self.session_daily: dict = {}
        # folded hour-grain in+out (for the historic max-5h baseline): hour_ts -> int
        self.hourly_io: dict = {}
        self.fold_ts: float = 0.0     # minutes older than this have been folded
        self.project_names: dict = {}  # project_dir -> display name
        # Per-session side data (latest seen). Updated as new events parse.
        self.session_meta: dict = {}   # sid -> {branch, cwd, project, model, last_ts}
        self.errors: int = 0      # count of malformed lines
        self._load_index()

    def _bucket(self, ts, sid, model, in_, out, cc, cr):
        key = (int(ts // 60) * 60, sid, model)
        b = self.minutes.get(key)
        if b is None:
            self.minutes[key] = [in_, out, cc, cr, 1]
        else:
            b[0] += in_
            b[1] += out
            b[2] += cc
            b[3] += cr
            b[4] += 1

    def _load_index(self):
        """Restore the parsed index from disk, if present and current.

        v2 loads natively. A v1 cache (raw event list) is MIGRATED in place —
        every event is bucketed, then folded — so the upgrade never pays the
        full ~minutes-long jsonl rescan; byte offsets carry over.
        Any other mismatch silently falls back to an empty index (one-time
        full rescan).
        """
        try:
            with open(INDEX_CACHE, "rb") as f:
                blob = pickle.load(f)
        except (OSError, pickle.UnpicklingError, EOFError, ValueError):
            return
        if not isinstance(blob, dict):
            return
        version = blob.get("version")
        try:
            if version == INDEX_CACHE_VERSION:
                self.files = {Path(k): v for k, v in blob["files"].items()}
                self.minutes = blob["minutes"]
                self.daily = blob["daily"]
                self.session_daily = blob["session_daily"]
                self.hourly_io = blob["hourly_io"]
                self.fold_ts = blob.get("fold_ts", 0.0)
                self.project_names = {Path(k): v for k, v in blob["project_names"].items()}
                self.session_meta = blob["session_meta"]
                self.errors = blob.get("errors", 0)
            elif version == 1 and "events" in blob:
                self.files = {Path(k): v for k, v in blob["files"].items()}
                self.project_names = {Path(k): v for k, v in blob["project_names"].items()}
                self.session_meta = blob["session_meta"]
                self.errors = blob.get("errors", 0)
                for e in blob["events"]:
                    # v1 tuple: (ts, project, sid, model, in, out, cc, cr)
                    self._bucket(e[0], e[2], e[3], e[4], e[5], e[6], e[7])
                self.prune()   # fold everything older than the minute tail
        except (KeyError, TypeError, AttributeError, IndexError):
            self.files, self.minutes = {}, {}
            self.daily, self.session_daily, self.hourly_io = {}, {}, {}
            self.fold_ts = 0.0
            self.project_names, self.session_meta, self.errors = {}, {}, 0

    def _session_project(self, sid: str) -> str:
        meta = self.session_meta.get(sid)
        return meta["project"] if meta and meta.get("project") else "?"

    def prune(self, now: float = None, days: int = AGG_RETENTION_DAYS):
        """Fold minute buckets older than the tail into day/hour aggregates,
        then drop aggregates beyond the retention horizon.

        File offsets are left untouched, so folded-away detail is never
        re-read. This is what keeps both memory and the on-disk cache bounded
        no matter how much Claude runs.
        """
        now = now if now is not None else time.time()
        cutoff = now - MINUTE_TAIL_HOURS * 3600
        if cutoff > self.fold_ts:
            self.fold_ts = cutoff
        old_keys = [k for k in self.minutes if k[0] < cutoff]
        for key in old_keys:
            m_ts, sid, model = key
            in_, out, cc, cr, msgs = self.minutes.pop(key)
            day = datetime.fromtimestamp(m_ts).date().isoformat()
            project = self._session_project(sid)
            for store, skey in ((self.daily, (day, project, model)),
                                (self.session_daily, (day, sid))):
                b = store.get(skey)
                if b is None:
                    store[skey] = [in_, out, cc, cr, msgs]
                else:
                    b[0] += in_; b[1] += out; b[2] += cc; b[3] += cr; b[4] += msgs
            h_ts = int(m_ts // 3600) * 3600
            self.hourly_io[h_ts] = self.hourly_io.get(h_ts, 0) + in_ + out
        horizon_day = (datetime.fromtimestamp(now).date() - timedelta(days=days)).isoformat()
        horizon_ts = now - days * 86400
        self.daily = {k: v for k, v in self.daily.items() if k[0] >= horizon_day}
        self.session_daily = {k: v for k, v in self.session_daily.items() if k[0] >= horizon_day}
        self.hourly_io = {k: v for k, v in self.hourly_io.items() if k >= horizon_ts}
        self.session_meta = {sid: m for sid, m in self.session_meta.items()
                             if m.get("last_ts", 0) >= horizon_ts}

    def save(self):
        """Atomically persist the index (folds + prunes first to bound size)."""
        self.prune()
        try:
            CACHE_DIR.mkdir(parents=True, exist_ok=True)
            blob = {
                "version": INDEX_CACHE_VERSION,
                "files": {str(k): v for k, v in self.files.items()},
                "minutes": self.minutes,
                "daily": self.daily,
                "session_daily": self.session_daily,
                "hourly_io": self.hourly_io,
                "fold_ts": self.fold_ts,
                "project_names": {str(k): v for k, v in self.project_names.items()},
                "session_meta": self.session_meta,
                "errors": self.errors,
            }
            tmp = INDEX_CACHE.parent / (INDEX_CACHE.name + ".tmp")
            with open(tmp, "wb") as f:
                pickle.dump(blob, f, protocol=5)
            os.replace(tmp, INDEX_CACHE)
        except (OSError, pickle.PicklingError):
            pass

    def _project_name(self, project_dir: Path) -> str:
        if project_dir not in self.project_names:
            self.project_names[project_dir] = _project_name_from_dir(project_dir)
        return self.project_names[project_dir]

    def refresh(self) -> int:
        """Returns number of new events added."""
        if not self.root.exists():
            return 0
        try:
            project_dirs = [p for p in self.root.iterdir() if p.is_dir()]
        except OSError:
            return 0
        added = 0
        for pdir in project_dirs:
            project = self._project_name(pdir)
            try:
                jsonls = list(pdir.glob("*.jsonl"))
            except OSError:
                continue
            for jpath in jsonls:
                try:
                    st = jpath.stat()
                except OSError:
                    continue
                meta = self.files.get(jpath)
                if meta is None:
                    self.files[jpath] = {"pos": 0, "project": project}
                    meta = self.files[jpath]
                if st.st_size < meta["pos"]:
                    # truncation/rotation — restart this file
                    meta["pos"] = 0
                if st.st_size > meta["pos"]:
                    added += self._read_from(jpath, meta, project)
        return added

    def _read_from(self, jpath: Path, meta: dict, project: str) -> int:
        try:
            with open(jpath, "rb") as f:
                f.seek(meta["pos"])
                data = f.read()
        except OSError:
            return 0
        # Only process complete lines; leave any tail for next refresh.
        end = data.rfind(b"\n")
        if end < 0:
            return 0
        complete = data[: end + 1]
        meta["pos"] += end + 1
        added = 0
        for raw in complete.splitlines():
            result = self._parse(raw)
            if result is None:
                continue
            ev_tuple, branch, cwd = result
            ts, sid, model, in_, out, cc, cr = ev_tuple
            self._bucket(ts, sid, model, in_, out, cc, cr)
            sm = self.session_meta.get(sid)
            if sm is None or ts >= sm.get("last_ts", 0):
                self.session_meta[sid] = {
                    "branch": branch,
                    "cwd": cwd,
                    "project": project,
                    "model": model,
                    "last_ts": ts,
                }
            added += 1
        return added

    def _parse(self, raw: bytes):
        """Returns ((ts, sid, model, in, out, cc, cr), branch, cwd) or None."""
        if not raw:
            return None
        try:
            d = json.loads(raw)
        except (json.JSONDecodeError, ValueError):
            self.errors += 1
            return None
        msg = d.get("message")
        if not isinstance(msg, dict):
            return None
        usage = msg.get("usage")
        if not isinstance(usage, dict):
            return None
        ts_str = d.get("timestamp")
        if not ts_str:
            return None
        try:
            ts = _iso_to_epoch(ts_str)
        except (ValueError, TypeError):
            self.errors += 1
            return None
        model = msg.get("model") or "?"
        sid = d.get("sessionId") or "?"
        ev = (
            ts, sid, model,
            int(usage.get("input_tokens", 0) or 0),
            int(usage.get("output_tokens", 0) or 0),
            int(usage.get("cache_creation_input_tokens", 0) or 0),
            int(usage.get("cache_read_input_tokens", 0) or 0),
        )
        return ev, d.get("gitBranch") or "", d.get("cwd") or ""

    # ── aggregations ────────────────────────────────────────────────

    def aggregate(self, since: float = None, until: float = None) -> dict:
        """Sum tokens within window. Returns dict with totals, by_project, by_model, by_session.

        Minute buckets give the recent tail at <=60s edge precision; windows
        reaching past the fold boundary add whole folded DAYS (a rolling 7d
        window therefore behaves as "the last 7 calendar days" at its far edge —
        the standard dashboard semantic).
        """
        z = lambda: dict(in_=0, out=0, cc=0, cr=0, msgs=0)  # noqa: E731
        by_proj = defaultdict(z)
        by_model = defaultdict(z)
        by_session = {}
        totals = z()

        def add(bucket, in_, out, cc, cr, msgs):
            bucket["in_"] += in_
            bucket["out"] += out
            bucket["cc"] += cc
            bucket["cr"] += cr
            bucket["msgs"] += msgs

        for (m_ts, sid, model), (in_, out, cc, cr, msgs) in self.minutes.items():
            if since is not None and m_ts < since - 59:
                continue
            if until is not None and m_ts > until:
                continue
            proj = self._session_project(sid)
            for bucket in (by_proj[proj], by_model[model], totals):
                add(bucket, in_, out, cc, cr, msgs)
            s = by_session.get(sid)
            if s is None:
                s = dict(in_=0, out=0, cc=0, cr=0, msgs=0,
                         project=proj, model=model, first=m_ts, last=m_ts)
                by_session[sid] = s
            add(s, in_, out, cc, cr, msgs)
            if m_ts > s["last"]:
                s["last"] = m_ts
                s["model"] = model  # keep last model used
            if m_ts < s["first"]:
                s["first"] = m_ts

        if since is not None and since < self.fold_ts and self.daily:
            since_day = datetime.fromtimestamp(since).date().isoformat()
            until_day = (datetime.fromtimestamp(until).date().isoformat()
                         if until is not None else "9999-12-31")
            for (day, proj, model), (in_, out, cc, cr, msgs) in self.daily.items():
                if day < since_day or day > until_day:
                    continue
                for bucket in (by_proj[proj], by_model[model], totals):
                    add(bucket, in_, out, cc, cr, msgs)
            for (day, sid), (in_, out, cc, cr, msgs) in self.session_daily.items():
                if day < since_day or day > until_day:
                    continue
                day_start = datetime.fromisoformat(day).timestamp()
                meta = self.session_meta.get(sid, {})
                s = by_session.get(sid)
                if s is None:
                    s = dict(in_=0, out=0, cc=0, cr=0, msgs=0,
                             project=meta.get("project", "?"),
                             model=meta.get("model", "?"),
                             first=day_start, last=day_start + 86399)
                    by_session[sid] = s
                add(s, in_, out, cc, cr, msgs)
                if day_start < s["first"]:
                    s["first"] = day_start

        return {
            "totals": totals,
            "by_project": dict(by_proj),
            "by_model": dict(by_model),
            "by_session": by_session,
        }

    def history_daily(self, days: int = 7) -> list:
        """Returns [(date, total_tokens), …] oldest → newest, len == days."""
        today = datetime.now().date()
        buckets = {today - timedelta(days=i): 0 for i in range(days)}
        for (day, _proj, _model), (in_, out, cc, cr, _msgs) in self.daily.items():
            d = datetime.fromisoformat(day).date()
            if d in buckets:
                buckets[d] += in_ + out + cc + cr
        for (m_ts, _sid, _model), (in_, out, cc, cr, _msgs) in self.minutes.items():
            d = datetime.fromtimestamp(m_ts).date()
            if d in buckets:
                buckets[d] += in_ + out + cc + cr
        return sorted(buckets.items())

    def session_events(self, sid: str) -> list:
        """The session's recent activity, oldest-first — one tuple per MINUTE
        bucket (same tuple shape the renderer always consumed). Sessions whose
        activity has folded past the minute tail show only their recent part;
        the live-tail view is for sessions that are, in fact, live.
        """
        proj = self._session_project(sid)
        evs = [
            (m_ts, proj, sid, model, v[0], v[1], v[2], v[3])
            for (m_ts, s, model), v in self.minutes.items()
            if s == sid
        ]
        evs.sort(key=lambda e: e[self.TS])
        return evs

    def recent_burn(self, now: float, lookback_seconds: int = 1800) -> float:
        """Tokens (in+out) per minute over the last lookback_seconds."""
        cutoff = now - lookback_seconds
        total = 0
        for (m_ts, _sid, _model), v in self.minutes.items():
            if m_ts >= cutoff - 59:
                total += v[0] + v[1]
        return total / (lookback_seconds / 60) if lookback_seconds > 0 else 0

    def hourly_peaks(self, now_ts: float, hours: int = 24) -> list:
        """For each of the last `hours` hours, return the *peak* tokens-per-minute
        (input and output, separately) observed within that hour.

        Same metric Anthropic's Console shows on the rate-limit charts —
        computed straight from the minute buckets (24h < MINUTE_TAIL_HOURS, so
        the whole chart lives at native resolution).

        Returns: [{"hour_ts": epoch, "max_in": int, "max_out": int}, …]
                 oldest first, length == hours.
        """
        end_hour = int(now_ts // 3600) * 3600
        start_hour = end_hour - (hours - 1) * 3600
        # minute_ts -> [in_sum, out_sum] (summed across sessions/models)
        by_minute: dict = defaultdict(lambda: [0, 0])
        for (m_ts, _sid, _model), v in self.minutes.items():
            if start_hour <= m_ts < end_hour + 3600:
                by_minute[m_ts][0] += v[0]
                by_minute[m_ts][1] += v[1]
        peaks = [{"hour_ts": start_hour + h * 3600, "max_in": 0, "max_out": 0}
                 for h in range(hours)]
        for m_ts, (mi_in, mi_out) in by_minute.items():
            hi = int((m_ts - start_hour) // 3600)
            if 0 <= hi < hours:
                if mi_in > peaks[hi]["max_in"]:
                    peaks[hi]["max_in"] = mi_in
                if mi_out > peaks[hi]["max_out"]:
                    peaks[hi]["max_out"] = mi_out
        return peaks

    def historic_max_5h(self, now: float, days: int = AGG_RETENTION_DAYS) -> tuple:
        """Busiest 5h window over the last `days` days, at HOUR grain.
        Returns (max_in_out_tokens, end_ts). Excludes the currently-open 5h
        window so the bar compares now vs. *previous* peaks, not now vs. itself.
        Hour-grain (5 consecutive hour buckets) — a baseline, not an audit.
        """
        hours: dict = dict(self.hourly_io)
        for (m_ts, _sid, _model), v in self.minutes.items():
            h = int(m_ts // 3600) * 3600
            hours[h] = hours.get(h, 0) + v[0] + v[1]
        cutoff_old = now - days * 86400
        last_end = int((now - 5 * 3600) // 3600) * 3600  # newest allowed window END
        best, best_end = 0, 0
        for h in hours:
            end = h + 3600
            if end > last_end or h < cutoff_old:
                continue
            running = sum(hours.get(h - i * 3600, 0) for i in range(5))
            if running > best:
                best, best_end = running, end
        return (best, best_end)


def total_tokens(bucket: dict) -> int:
    return bucket["in_"] + bucket["out"] + bucket["cc"] + bucket["cr"]


def window_bounds(mode: str, now: float) -> tuple:
    """Returns (since, until, label) for a window mode."""
    for name, span in WINDOW_MODES:
        if name == mode:
            if span == "today":
                start = datetime.fromtimestamp(now).replace(
                    hour=0, minute=0, second=0, microsecond=0
                ).timestamp()
                return start, now, "today"
            return now - span, now, name
    return now - 5 * 3600, now, "5h"


